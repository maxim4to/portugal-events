---
import Base from '../../layouts/Base.astro';
import TypeBadge from '../../components/TypeBadge.astro';
import Icon from '../../components/Icon.astro';
import MiniMap from '../../components/MiniMap.astro';
import VisitedButton from '../../components/VisitedButton.astro';
import VisitedController from '../../components/VisitedController.astro';
import FavoriteButton from '../../components/FavoriteButton.astro';
import FavoriteController from '../../components/FavoriteController.astro';
import NotInterestedButton from '../../components/NotInterestedButton.astro';
import NotInterestedController from '../../components/NotInterestedController.astro';
import PhotoGallery from '../../components/PhotoGallery.astro';
import { allPlaces } from '../../lib/data.ts';
import type { Place } from '../../../schema/index.ts';

export function getStaticPaths() {
  return allPlaces.map((place) => ({ params: { id: place.id }, props: { place } }));
}
const { place } = Astro.props as { place: Place };
const href = (p: string) => import.meta.env.BASE_URL.replace(/\/$/, '') + p;
// Open the place itself on Google Maps (photos/reviews/hours), not just a pin.
// The id slug is the Portuguese/Latin name (e.g. "praia-da-arrifana"), which
// Google resolves far more reliably than the Cyrillic display name; anchor the
// search at the coords so it lands on the right object even for generic names.
const gmapsQuery = place.id.replace(/-/g, ' ');
const gmapsPlace = `https://www.google.com/maps/search/${encodeURIComponent(gmapsQuery)}/@${place.coords.lat},${place.coords.lon},16z`;
const paragraphs = place.description.split(/\n\n+/).map((s) => s.trim()).filter(Boolean);
const cover = place.photos[0];
---
<Base title={place.name} description={place.description.slice(0, 150)}>
  <article class="detail">
    <a class="back-top" href={href('/places/')}>
      <Icon name="arrow-left" size={14} /> Ко всем местам
    </a>

    <header class="head">
      <span class="head-kicker">
        <TypeBadge type={place.type} />
        <a class="region" href={href('/places/?region=' + encodeURIComponent(place.region))}>{place.region}</a>
      </span>
      <h1>{place.name}</h1>
      <div class="meta-row byline">
        <span><Icon name="clock" size={13} /> {place.driveMinutesFromLisbon} мин на машине</span>
        <span><Icon name="hourglass" size={13} /> ~{place.visitDurationHours} ч на месте</span>
        <span><Icon name="calendar" size={13} /> {place.bestSeason}</span>
      </div>
    </header>

    <div class="hero">
      <PhotoGallery photos={place.photos} alt={place.name} variant="detail" type={place.type} />
    </div>

    {place.freeWithResidency === true && (
      <span class="residency-pill">Бесплатно с ВНЖ</span>
    )}

    <div class="description">
      {paragraphs.map((p) => <p>{p}</p>)}
    </div>

    {place.tags.length > 0 && (
      <div class="tags">
        {place.tags.map((tag) => (
          <a class="badge tag" href={href('/places/?tag=' + encodeURIComponent(tag))}>{tag}</a>
        ))}
      </div>
    )}

    {place.links.length > 0 && (
      <ul class="links">
        {place.links.map((link) => (
          <li><a href={link.url} target="_blank" rel="noopener">{link.title}</a></li>
        ))}
      </ul>
    )}

    <div class="actions">
      <a class="btn btn-primary" href={gmapsPlace} target="_blank" rel="noopener">Открыть в Google Maps</a>
      <FavoriteButton placeId={place.id} variant="detail" />
      <VisitedButton placeId={place.id} variant="detail" />
      <NotInterestedButton placeId={place.id} variant="detail" />
    </div>

    <MiniMap lat={place.coords.lat} lon={place.coords.lon} name={place.name} />

    {cover && (
      <p class="muted attribution" data-gallery-attrib>
        Фото: <a href={cover.sourceUrl} target="_blank" rel="noopener">{cover.author}, {cover.license}</a>
      </p>
    )}
  </article>

  <VisitedController />
  <FavoriteController />
  <NotInterestedController />
</Base>

<style>
  .detail {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 720px;
    margin: 0 auto;
  }
  .head {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .head-kicker {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  .hero {
    position: relative;
  }
  .detail h1 {
    margin: 0;
    font-size: clamp(32px, 5vw, 48px);
  }
  .byline {
    padding-top: var(--space-2);
    border-top: 1px solid var(--border-strong);
    font-size: 13px;
  }
  .byline span {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    /* Never break a single fact mid-phrase (e.g. "65 мин на машине"). */
    white-space: nowrap;
  }
  /* On phones the three facts don't fit on one row; stack them cleanly instead
     of wrapping with a "·" separator dangling at the start of a line. */
  @media (max-width: 760px) {
    .byline {
      flex-direction: column;
      align-items: flex-start;
      row-gap: var(--space-2);
    }
    .byline > * + *::before {
      content: none;
    }
  }
  .back-top {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    align-self: flex-start;
    color: var(--text-secondary);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .back-top:hover {
    color: var(--editorial);
    text-decoration: none;
  }
  .region {
    color: var(--text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--border-strong);
    font-size: 13px;
  }
  .region:hover {
    color: var(--editorial);
  }
  .residency-pill {
    align-self: flex-start;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px var(--space-3);
    border-radius: var(--radius);
    background: var(--type-hike);
    color: var(--type-hike-text);
  }
  .description {
    font-family: var(--font-display);
    font-size: 18px;
    line-height: 1.7;
    color: var(--text-primary);
  }
  /* Editorial drop cap on the opening paragraph. */
  .description p:first-of-type::first-letter {
    font-weight: 600;
    font-size: 3.4em;
    line-height: 0.8;
    float: left;
    margin: 0.04em 0.08em 0 0;
    color: var(--editorial);
  }
  .description p:last-child {
    margin-bottom: 0;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .tag {
    background: var(--surface-2);
    border: 0.5px solid var(--border);
    color: var(--text-secondary);
    text-decoration: none;
  }
  .tag:hover {
    border-color: var(--border-strong);
    text-decoration: none;
  }
  .links {
    margin: 0;
    padding-left: var(--space-4);
    font-size: 14px;
  }
  .links a {
    color: var(--accent);
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin: var(--space-2) 0;
  }
  .attribution {
    font-size: 12px;
    margin: 0;
  }
  .attribution a {
    color: inherit;
    text-decoration: underline;
  }
</style>
