---
import Base from '../layouts/Base.astro';
import PlacesExplorer from '../components/PlacesExplorer.astro';
import { allPlaces, regions, allTags } from '../lib/data.ts';
const hrefBase = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Base title="Места — Португалия" description="Каталог мест Португалии: пляжи, замки, хайкинг, виды." wide>
  <h1 class="sr-only">Места Португалии</h1>
  <PlacesExplorer places={allPlaces} regions={regions} tags={allTags} hrefBase={hrefBase} />
</Base>
