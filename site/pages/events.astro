---
import Base from '../layouts/Base.astro';
import EventsExplorer from '../components/EventsExplorer.astro';
import { upcomingEvents, cities } from '../lib/data.ts';
import { buildCityIndex, eventLatLon } from '../lib/eventGeo.ts';
import { EVENT_TYPE_LABELS } from '../lib/labels.ts';
import { formatDateRu } from '../lib/dates.ts';
import { imageThumb } from '../lib/imgProxy.ts';
import type { MapPoint } from '../lib/mapExplorer.ts';

const hrefBase = import.meta.env.BASE_URL.replace(/\/$/, '');
const cityIndex = buildCityIndex(cities);

const points: MapPoint[] = [];
for (const e of upcomingEvents) {
  const ll = eventLatLon(e, cityIndex);
  if (!ll) continue;
  const date =
    e.dateStart === e.dateEnd
      ? formatDateRu(e.dateStart)
      : `${formatDateRu(e.dateStart)} – ${formatDateRu(e.dateEnd)}`;
  points.push({
    id: e.id,
    name: e.title,
    lat: ll.lat,
    lon: ll.lon,
    type: e.type,
    image: e.image ? imageThumb(e.image, 320, 200) : undefined,
    kicker: EVENT_TYPE_LABELS[e.type] ?? 'Событие',
    meta: `${date} · ${e.city}`,
  });
}
---
<Base
  title="Афиша — Португалия"
  description="Концерты, фестивали и события в Португалии."
  wide
>
  <h1 class="sr-only">Афиша</h1>
  <EventsExplorer events={upcomingEvents} points={points} hrefBase={hrefBase} cities={cities} />
</Base>
