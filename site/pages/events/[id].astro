---
import Base from '../../layouts/Base.astro';
import MiniMap from '../../components/MiniMap.astro';
import Icon from '../../components/Icon.astro';
import { upcomingEvents, cities } from '../../lib/data.ts';
import { buildCityIndex, eventLatLon } from '../../lib/eventGeo.ts';
import { EVENT_TYPE_LABELS } from '../../lib/labels.ts';
import { formatDateRu } from '../../lib/dates.ts';
import type { Event } from '../../../schema/index.ts';

export function getStaticPaths() {
  return upcomingEvents.map((event) => ({ params: { id: event.id }, props: { event } }));
}
const { event } = Astro.props as { event: Event };
const href = (p: string) => import.meta.env.BASE_URL.replace(/\/$/, '') + p;

const dateLabel =
  event.dateStart === event.dateEnd
    ? formatDateRu(event.dateStart)
    : `${formatDateRu(event.dateStart)} – ${formatDateRu(event.dateEnd)}`;

const coords = eventLatLon(event, buildCityIndex(cities));
const paragraphs = event.description.split(/\n\n+/).map((s) => s.trim()).filter(Boolean);
---
<Base title={event.title} description={event.description.slice(0, 150)}>
  <article class="detail">
    <a class="back-top" href={href('/events/')}>
      <Icon name="arrow-left" size={16} /> Ко всем событиям
    </a>

    {event.image && (
      <div class="hero">
        <img src={event.image} alt={event.title} referrerpolicy="no-referrer" />
      </div>
    )}

    <span class="badge event-badge">{EVENT_TYPE_LABELS[event.type] ?? 'Событие'}</span>
    <h1>{event.title}</h1>

    <div class="meta-row">
      <span>{dateLabel}</span>
      <span>{event.city}, {event.venue}</span>
      {event.price && <span>{event.price}</span>}
    </div>

    {paragraphs.length > 0 && (
      <div class="description">
        {paragraphs.map((p) => <p>{p}</p>)}
      </div>
    )}

    <div class="actions">
      <a class="btn btn-primary" href={event.url} target="_blank" rel="noopener">Подробнее на сайте</a>
    </div>

    {coords && <MiniMap lat={coords.lat} lon={coords.lon} name={event.title} />}

    <p class="back"><a href={href('/events/')}>← Ко всем событиям</a></p>
  </article>
</Base>

<style>
  .detail {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 760px;
    margin: 0 auto;
  }
  .hero {
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--accent-bg);
  }
  .hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .back-top {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    align-self: flex-start;
    color: var(--text-secondary);
    font-size: 14px;
  }
  .back-top:hover {
    color: var(--text-primary);
    text-decoration: none;
  }
  .event-badge {
    align-self: flex-start;
    background: var(--accent-bg);
    color: var(--accent-text);
  }
  .detail h1 {
    margin: 0;
  }
  .description {
    margin-top: var(--space-2);
  }
  .description p:last-child {
    margin-bottom: 0;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin: var(--space-2) 0;
  }
  .back {
    margin-top: var(--space-3);
  }
  .back a {
    color: var(--accent);
  }
</style>
