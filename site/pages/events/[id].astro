---
import Base from '../../layouts/Base.astro';
import MiniMap from '../../components/MiniMap.astro';
import Icon from '../../components/Icon.astro';
import { upcomingEvents, cities } from '../../lib/data.ts';
import { buildCityIndex, eventLatLon, driveTimeFromLisbon } from '../../lib/eventGeo.ts';
import { EVENT_TYPE_LABELS } from '../../lib/labels.ts';
import { formatDateRu } from '../../lib/dates.ts';
import { imageThumb } from '../../lib/imgProxy.ts';
import type { Event } from '../../../schema/index.ts';

export function getStaticPaths() {
  return upcomingEvents.map((event) => ({ params: { id: event.id }, props: { event } }));
}
const { event } = Astro.props as { event: Event };
const href = (p: string) => import.meta.env.BASE_URL.replace(/\/$/, '') + p;

const dateLabel =
  event.dateStart === event.dateEnd
    ? formatDateRu(event.dateStart)
    : `${formatDateRu(event.dateStart)} – ${formatDateRu(event.dateEnd)}`;

const cityIndex = buildCityIndex(cities);
const coords = eventLatLon(event, cityIndex);
const driveTime = driveTimeFromLisbon(event, cityIndex);
const paragraphs = event.description.split(/\n\n+/).map((s) => s.trim()).filter(Boolean);
---
<Base title={event.title} description={event.description.slice(0, 150)}>
  <article class="detail">
    <a class="back-top" href={href('/events/')}>
      <Icon name="arrow-left" size={14} /> Ко всем событиям
    </a>

    <header class="head">
      <span class="head-kicker">
        <span class="badge event-badge">{EVENT_TYPE_LABELS[event.type] ?? 'Событие'}</span>
        <span class="head-date">{dateLabel}</span>
      </span>
      <h1>{event.title}</h1>
      <div class="meta-row byline">
        <span>{event.city}, {event.venue}</span>
        {driveTime && <span>{driveTime}</span>}
        {event.price && <span>{event.price}</span>}
      </div>
    </header>

    {event.image && (
      <div class="hero">
        <img
          src={imageThumb(event.image, 1000, 560)}
          data-fallback={event.image}
          alt={event.title}
          decoding="async"
          referrerpolicy="no-referrer"
          onerror="this.onerror=null;this.src=this.dataset.fallback"
        />
      </div>
    )}

    {paragraphs.length > 0 && (
      <div class="description">
        {paragraphs.map((p) => <p>{p}</p>)}
      </div>
    )}

    <div class="actions">
      <a class="btn btn-primary" href={event.url} target="_blank" rel="noopener">Подробнее на сайте</a>
    </div>

    {coords && <MiniMap lat={coords.lat} lon={coords.lon} name={event.title} />}

    <p class="back"><a href={href('/events/')}>← Ко всем событиям</a></p>
  </article>
</Base>

<style>
  .detail {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 720px;
    margin: 0 auto;
  }
  .head {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .head-kicker {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  .head-date {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text-secondary);
  }
  .hero {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--accent-bg);
    border: 1px solid var(--border-strong);
  }
  .hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .back-top {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    align-self: flex-start;
    color: var(--text-secondary);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .back-top:hover {
    color: var(--editorial);
    text-decoration: none;
  }
  .event-badge {
    align-self: flex-start;
    background: var(--accent-bg);
    color: var(--accent-text);
  }
  .detail h1 {
    margin: 0;
    font-size: clamp(32px, 5vw, 48px);
  }
  .byline {
    padding-top: var(--space-2);
    border-top: 1px solid var(--border-strong);
    font-size: 13px;
  }
  .description {
    font-family: var(--font-display);
    font-size: 18px;
    line-height: 1.7;
    color: var(--text-primary);
  }
  .description p:first-of-type::first-letter {
    font-weight: 600;
    font-size: 3.4em;
    line-height: 0.8;
    float: left;
    margin: 0.04em 0.08em 0 0;
    color: var(--editorial);
  }
  .description p:last-child {
    margin-bottom: 0;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin: var(--space-2) 0;
  }
  .back {
    margin-top: var(--space-3);
  }
  .back a {
    color: var(--accent);
  }
</style>
