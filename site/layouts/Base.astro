---
import '../styles/tokens.css';
import '../styles/base.css';
import Header from '../components/Header.astro';

interface Props {
  title: string;
  description?: string;
  /** Wide layout for the map explorer pages (drops the reading-width cap). */
  wide?: boolean;
}
const { title, description, wide } = Astro.props;
const href = (p: string) => import.meta.env.BASE_URL.replace(/\/$/, '') + p;
---
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description ?? 'Места и события в Португалии'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..600&family=Inter:wght@400..600&display=swap"
    />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'dark' || t === 'light') {
            document.documentElement.dataset.theme = t;
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class:list={{ 'app-fill': wide }}>
    <Header />
    <main class:list={['main', { wide }]}>
      <slot />
    </main>
  </body>
</html>

<style>
  .main {
    max-width: 1100px;
    margin: 0 auto;
    padding: var(--space-5) var(--space-4) var(--space-6);
  }

  /* Explorer pages: lock the app to the viewport so only the list scrolls —
     never the page itself. */
  :global(body.app-fill) {
    height: 100dvh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .main.wide {
    /* width:100% gives a definite cross-axis size so the flex column always
       stretches to the viewport. Without it, `margin:0 auto` disables stretch
       and the width becomes content-driven (differs per page). */
    width: 100%;
    max-width: 1400px;
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    padding-top: var(--space-4);
    padding-bottom: var(--space-4);
  }
</style>
