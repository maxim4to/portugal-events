---
import '../styles/tokens.css';
import '../styles/base.css';
import Header from '../components/Header.astro';

interface Props {
  title: string;
  description?: string;
  /** Wide layout for the map explorer pages (drops the reading-width cap). */
  wide?: boolean;
}
const { title, description, wide } = Astro.props;
const href = (p: string) => import.meta.env.BASE_URL.replace(/\/$/, '') + p;
---
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description ?? 'Места и события в Португалии'} />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'dark' || t === 'light') {
            document.documentElement.dataset.theme = t;
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <Header />
    <main class:list={['main', { wide }]}>
      <slot />
    </main>
    <footer class="container">
      <p class="muted footer-text">
        Данные карт — © OpenStreetMap. Фотографии — Wikimedia Commons.
      </p>
    </footer>
  </body>
</html>

<style>
  .main {
    max-width: 1100px;
    margin: 0 auto;
    padding: var(--space-5) var(--space-4) var(--space-6);
  }
  .main.wide {
    max-width: 1400px;
  }
  .footer-text {
    font-size: 12px;
    padding-top: var(--space-5);
    padding-bottom: var(--space-5);
    border-top: 0.5px solid var(--border);
  }
</style>
