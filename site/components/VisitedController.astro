---
// Shared client controller for the "visited" feature. Include once on any page
// that renders VisitedButton(s). It:
//  - hides all .visited-btn (and the catalog visited filter) when unconfigured
//  - subscribes to the shared visited set and reflects it onto buttons +
//    the [data-place-card] wrappers (via data-visited) so filtering can use it
//  - toggles visited on click, guarding against anchor navigation
---
<script>
  import {
    subscribeVisited,
    setVisited,
    isConfigured,
  } from '../lib/visited.ts';

  const buttons = Array.from(
    document.querySelectorAll<HTMLButtonElement>('.visited-btn'),
  );

  if (!isConfigured()) {
    // Inert: hide every toggle and the visited filter control, and mark the
    // explorer so the catalog can drop the filter from its layout.
    buttons.forEach((btn) => (btn.hidden = true));
    document
      .querySelectorAll<HTMLElement>('[data-filter="visited"]')
      .forEach((el) => {
        const wrap = el.closest<HTMLElement>('[data-visited-control]') ?? el;
        wrap.hidden = true;
      });
    document
      .querySelectorAll<HTMLElement>('[data-explorer]')
      .forEach((el) => (el.dataset.visitedConfigured = 'false'));
  } else {
    document
      .querySelectorAll<HTMLElement>('[data-explorer]')
      .forEach((el) => (el.dataset.visitedConfigured = 'true'));
    // Reveal the catalog visited filter (hidden by default in markup).
    document
      .querySelectorAll<HTMLElement>('[data-filter="visited"]')
      .forEach((el) => {
        const wrap = el.closest<HTMLElement>('[data-visited-control]') ?? el;
        wrap.hidden = false;
      });

    const reflect = (ids: Set<string>) => {
      for (const btn of buttons) {
        const id = btn.dataset.visitedId!;
        const on = ids.has(id);
        btn.hidden = false;
        btn.setAttribute('aria-pressed', on ? 'true' : 'false');
        const label = btn.querySelector('.visited-label');
        if (label) label.textContent = on ? 'Вы были здесь' : 'Был здесь';
        // Reflect onto the enclosing catalog card wrapper for filtering.
        const wrapper = btn.closest<HTMLElement>('[data-place-card]');
        if (wrapper) wrapper.dataset.visited = on ? 'true' : 'false';
      }
      // Cards without a button still need a data-visited baseline for filtering.
      document
        .querySelectorAll<HTMLElement>('[data-place-card]')
        .forEach((wrap) => {
          const id = wrap.dataset.id!;
          if (wrap.dataset.visited === undefined || wrap.querySelector('.visited-btn')) {
            wrap.dataset.visited = ids.has(id) ? 'true' : 'false';
          }
        });
      // Let the explorer re-run its filter now that visited state changed.
      document.dispatchEvent(new CustomEvent('visited:changed'));
    };

    subscribeVisited(reflect);

    for (const btn of buttons) {
      btn.addEventListener('click', (e) => {
        // The card button lives inside an <a>; do not navigate.
        e.preventDefault();
        e.stopPropagation();
        const id = btn.dataset.visitedId!;
        const next = btn.getAttribute('aria-pressed') !== 'true';
        // Optimistic reflect; the subscription will confirm/correct.
        btn.setAttribute('aria-pressed', next ? 'true' : 'false');
        void setVisited(id, next);
      });
    }
  }
</script>
