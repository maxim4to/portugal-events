---
import type { Photo } from '../../schema/index.ts';
import Icon from './Icon.astro';

interface Props {
  photos: Photo[];
  alt: string;
  variant: 'card' | 'detail';
  type: string;
}
const { photos, alt, variant, type } = Astro.props;
const hasPhotos = photos.length > 0;
const multi = photos.length > 1;
// Serialize per-photo attribution so the controller can update the detail line.
const attribData = photos.map((p) => ({
  author: p.author,
  license: p.license,
  sourceUrl: p.sourceUrl,
}));
---
<div
  class:list={['gallery', `gallery-${variant}`]}
  data-gallery
  data-count={photos.length}
  style={hasPhotos ? undefined : `background: var(--type-${type});`}
>
  {photos.map((photo, i) => (
    <img
      class="layer"
      data-photo-index={i}
      src={i === 0 ? photo.url : undefined}
      data-src={i === 0 ? undefined : photo.url}
      alt={alt}
      loading="lazy"
      draggable="false"
      style={i === 0 ? 'opacity:1' : 'opacity:0'}
    />
  ))}

  {variant === 'detail' && multi && (
    <>
      <button type="button" class="nav nav-prev" data-nav="prev" aria-label="Предыдущее фото">
        <Icon name="chevron-left" size={22} />
      </button>
      <button type="button" class="nav nav-next" data-nav="next" aria-label="Следующее фото">
        <Icon name="chevron-right" size={22} />
      </button>
    </>
  )}

  {multi && (
    <div class="dots" data-dots>
      {photos.map((_, i) => (
        <button
          type="button"
          class="dot"
          data-dot={i}
          aria-label={`Фото ${i + 1}`}
          aria-current={i === 0 ? 'true' : 'false'}
        />
      ))}
    </div>
  )}

  {variant === 'detail' && hasPhotos && (
    <script type="application/json" data-gallery-attribs set:html={JSON.stringify(attribData)}></script>
  )}
</div>

<style>
  .gallery {
    position: relative;
    overflow: hidden;
    background: var(--surface-1);
    touch-action: pan-y;
  }
  .gallery-card {
    aspect-ratio: 16 / 10;
  }
  .gallery-detail {
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-strong);
  }
  .layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.15s ease;
    -webkit-user-select: none;
    user-select: none;
  }
  /* Dots */
  .dots {
    position: absolute;
    bottom: var(--space-2);
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: 6px;
    z-index: 3;
    pointer-events: none;
  }
  .dot {
    pointer-events: auto;
    width: 7px;
    height: 7px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.55);
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.25), 0 1px 2px rgba(0, 0, 0, 0.35);
    cursor: pointer;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .dot[aria-current='true'] {
    background: #ffffff;
    transform: scale(1.25);
  }
  .gallery-detail .dot {
    width: 9px;
    height: 9px;
  }
  /* Nav arrows (detail only) */
  .nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    padding: 0;
    border: none;
    border-radius: 50%;
    color: #fff;
    background: rgba(0, 0, 0, 0.4);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s ease, background 0.15s ease;
  }
  .gallery-detail:hover .nav,
  .nav:focus-visible {
    opacity: 1;
  }
  .nav:hover {
    background: rgba(0, 0, 0, 0.6);
  }
  .nav-prev {
    left: var(--space-3);
  }
  .nav-next {
    right: var(--space-3);
  }
  /* Touch devices: arrows always visible (no hover). */
  @media (hover: none) {
    .nav {
      opacity: 1;
    }
  }
</style>

<script>
  // Shared gallery controller. Astro bundles this module once per page,
  // so it initializes every [data-gallery] regardless of instance count.
  (function () {
    function lazyLoad(img: HTMLImageElement) {
      const ds = img.getAttribute('data-src');
      if (ds && !img.getAttribute('src')) {
        img.setAttribute('src', ds);
        img.removeAttribute('data-src');
      }
    }

    function initGallery(root: HTMLElement) {
      try {
        const count = Number(root.dataset.count || '0');
        const layers = Array.from(
          root.querySelectorAll<HTMLImageElement>('[data-photo-index]'),
        );
        const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-dot]'));
        const isDetail = root.classList.contains('gallery-detail');
        let current = 0;

        // Detail attribution wiring.
        let attribs: Array<{ author: string; license: string; sourceUrl: string }> = [];
        let attribEl: HTMLElement | null = null;
        if (isDetail) {
          const dataEl = root.querySelector<HTMLElement>('[data-gallery-attribs]');
          if (dataEl && dataEl.textContent) {
            try {
              attribs = JSON.parse(dataEl.textContent);
            } catch (e) {
              attribs = [];
            }
          }
          attribEl = document.querySelector<HTMLElement>('[data-gallery-attrib]');
        }

        function updateAttrib(i: number) {
          if (!attribEl || !attribs[i]) return;
          const a = attribs[i];
          const link = attribEl.querySelector('a');
          if (link) {
            link.textContent = `${a.author}, ${a.license}`;
            link.setAttribute('href', a.sourceUrl);
          }
        }

        function show(index: number) {
          if (count <= 1) return;
          const i = ((index % count) + count) % count;
          if (i === current && layers[i] && layers[i].getAttribute('src')) return;
          current = i;
          layers.forEach((layer, li) => {
            layer.style.opacity = li === i ? '1' : '0';
          });
          if (layers[i]) lazyLoad(layers[i]);
          dots.forEach((d, di) => d.setAttribute('aria-current', di === i ? 'true' : 'false'));
          updateAttrib(i);
        }

        if (count <= 1) return; // Single image or fallback: nothing to wire.

        // Dots: click jumps; never navigate the parent link.
        dots.forEach((dot, di) => {
          dot.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            show(di);
          });
        });

        // Detail arrows.
        root.querySelectorAll<HTMLButtonElement>('[data-nav]').forEach((btn) => {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            show(current + (btn.dataset.nav === 'next' ? 1 : -1));
          });
        });

        // Desktop hover mapping (card variant): X position -> zone -> index.
        if (!isDetail) {
          root.addEventListener('mousemove', (e) => {
            const rect = root.getBoundingClientRect();
            if (rect.width <= 0) return;
            const ratio = Math.min(0.9999, Math.max(0, (e.clientX - rect.left) / rect.width));
            show(Math.floor(ratio * count));
          });
          root.addEventListener('mouseleave', () => show(0));
        }

        // Detail keyboard (nice-to-have).
        if (isDetail) {
          root.setAttribute('tabindex', '0');
          root.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowLeft') {
              e.preventDefault();
              show(current - 1);
            } else if (e.key === 'ArrowRight') {
              e.preventDefault();
              show(current + 1);
            }
          });
        }

        // Touch swipe (both variants).
        let startX = 0;
        let startY = 0;
        let tracking = false;
        let horizontal = false;
        root.addEventListener(
          'touchstart',
          (e) => {
            if (e.touches.length !== 1) return;
            startX = e.touches[0].clientX;
            startY = e.touches[0].clientY;
            tracking = true;
            horizontal = false;
          },
          { passive: true },
        );
        root.addEventListener(
          'touchmove',
          (e) => {
            if (!tracking || e.touches.length !== 1) return;
            const dx = e.touches[0].clientX - startX;
            const dy = e.touches[0].clientY - startY;
            if (!horizontal && Math.abs(dx) > 10 && Math.abs(dx) > Math.abs(dy)) {
              horizontal = true;
            }
            // Once clearly horizontal, block link navigation / vertical scroll.
            if (horizontal && e.cancelable) e.preventDefault();
          },
          { passive: false },
        );
        root.addEventListener(
          'touchend',
          (e) => {
            if (!tracking) return;
            tracking = false;
            if (!horizontal) return; // A plain tap: let the card link handle it.
            const endX = (e.changedTouches[0] && e.changedTouches[0].clientX) || startX;
            const dx = endX - startX;
            if (Math.abs(dx) < 40) return;
            show(current + (dx < 0 ? 1 : -1));
          },
          { passive: true },
        );

        // Trackpad swipe (two-finger horizontal gesture -> wheel deltaX).
        let wheelAccumX = 0;
        let wheelLocked = false;
        let wheelResetTimer: number | undefined;
        root.addEventListener(
          'wheel',
          (e) => {
            if (Math.abs(e.deltaX) <= Math.abs(e.deltaY)) return; // vertical scroll: ignore
            if (e.cancelable) e.preventDefault();
            if (wheelLocked) return;
            wheelAccumX += e.deltaX;
            clearTimeout(wheelResetTimer);
            wheelResetTimer = window.setTimeout(() => {
              wheelAccumX = 0;
            }, 200);
            if (Math.abs(wheelAccumX) > 50) {
              show(current + (wheelAccumX > 0 ? 1 : -1));
              wheelAccumX = 0;
              wheelLocked = true;
              window.setTimeout(() => {
                wheelLocked = false;
              }, 350);
            }
          },
          { passive: false },
        );
      } catch (err) {
        /* Never throw. */
      }
    }

    function initAll() {
      document.querySelectorAll<HTMLElement>('[data-gallery]').forEach(initGallery);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAll);
    } else {
      initAll();
    }
  })();
</script>
