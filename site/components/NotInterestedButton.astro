---
interface Props {
  placeId: string;
  variant?: 'card' | 'detail';
}
const { placeId, variant = 'detail' } = Astro.props;
---
<button
  type="button"
  class:list={['ni-btn', `ni-btn--${variant}`, { 'icon-tip': variant === 'card' }]}
  data-ni-id={placeId}
  data-tip="Не интересно"
  data-tip-on="Скрыто"
  aria-pressed="false"
  aria-label="Не интересно"
  hidden
>
  {/* Not-interested: a slashed circle ("no"). Pressed: the same circle filled,
      the slash cut out in the surface colour. Swapped purely by aria-pressed. */}
  <svg
    class="ni-icon"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="9" />
    <line x1="5.6" y1="5.6" x2="18.4" y2="18.4" />
  </svg>
  <svg
    class="ni-icon-on"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="9" fill="currentColor" stroke="currentColor" stroke-width="2" />
    <line
      x1="5.6"
      y1="5.6"
      x2="18.4"
      y2="18.4"
      stroke="var(--surface-2)"
      stroke-width="2.4"
      stroke-linecap="round"
    />
  </svg>
  <span class="ni-label">Не интересно</span>
</button>

<style>
  .ni-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface-2);
    color: var(--text-secondary);
    font: inherit;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
  }
  .ni-btn:hover {
    border-color: var(--border-strong);
  }
  .ni-btn:active {
    transform: scale(0.94);
  }
  /* Pressed = not interested: the slashed circle fills in the muted grey. */
  .ni-btn[aria-pressed='true'] {
    color: var(--not-interested);
    border-color: var(--not-interested);
  }
  .ni-btn[aria-pressed='true'] .ni-icon-on {
    animation: toggle-pop 180ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .ni-icon,
  .ni-icon-on {
    flex: none;
  }
  .ni-icon-on {
    display: none;
  }
  .ni-btn[aria-pressed='true'] .ni-icon {
    display: none;
  }
  .ni-btn[aria-pressed='true'] .ni-icon-on {
    display: block;
  }

  /* Compact circular overlay for catalog cards. Mirrors the visited/favorite
     card buttons exactly — same shell, only the icon and pressed tint differ. */
  .ni-btn--card {
    width: 32px;
    height: 32px;
    padding: 0;
    justify-content: center;
    border-radius: var(--radius-pill);
    border: 0.5px solid var(--border);
    color: var(--text-primary);
    background: color-mix(in srgb, var(--surface-2) 85%, transparent);
    backdrop-filter: blur(3px);
    box-shadow: 0 1px 4px rgba(33, 29, 23, 0.22);
  }
  .ni-btn--card .ni-icon,
  .ni-btn--card .ni-icon-on {
    width: 18px;
    height: 18px;
  }
  /* Icon-only on cards: meaning carried by the hover tip, not a label. */
  .ni-btn--card .ni-label {
    display: none;
  }
  .ni-btn--card[aria-pressed='true'] {
    color: var(--not-interested);
    border-color: var(--not-interested);
  }
  /* Bigger tap target on phones — 32px is fiddly under a finger. */
  @media (max-width: 760px) {
    .ni-btn--card {
      width: 44px;
      height: 44px;
    }
    .ni-btn--card .ni-icon,
    .ni-btn--card .ni-icon-on {
      width: 22px;
      height: 22px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .ni-btn {
      transition: none;
    }
    .ni-btn:active {
      transform: none;
    }
    .ni-btn[aria-pressed='true'] .ni-icon-on {
      animation: none;
    }
  }
</style>
