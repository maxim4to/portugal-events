---
interface Props {
  placeId: string;
  variant?: 'card' | 'detail';
}
const { placeId, variant = 'detail' } = Astro.props;
---
<button
  type="button"
  class:list={['visited-btn', `visited-btn--${variant}`, { 'icon-tip': variant === 'card' }]}
  data-visited-id={placeId}
  data-tip="Был здесь"
  data-tip-on="Отмечено"
  aria-pressed="false"
  aria-label="Был здесь"
  hidden
>
  <svg
    class="visited-icon"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M20 6 9 17l-5-5" />
  </svg>
  <span class="visited-label">Был здесь</span>
</button>

<style>
  .visited-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface-2);
    color: var(--text-secondary);
    font: inherit;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
  }
  .visited-btn:hover {
    border-color: var(--border-strong);
  }
  .visited-btn:active {
    transform: scale(0.94);
  }
  /* Pressed = visited: success/teal tint built from the lake tokens. */
  .visited-btn[aria-pressed='true'] {
    background: var(--type-lake);
    color: var(--type-lake-text);
    border-color: var(--type-lake-text);
  }
  .visited-btn[aria-pressed='true'] .visited-icon {
    animation: toggle-pop 180ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .visited-icon {
    flex: none;
  }

  /* Compact circular overlay for catalog cards. Mirrors FavoriteButton's card
     variant exactly — same shell, only the icon and pressed tint differ. */
  .visited-btn--card {
    width: 32px;
    height: 32px;
    padding: 0;
    justify-content: center;
    border-radius: var(--radius-pill);
    border: 0.5px solid var(--border);
    color: var(--text-primary);
    background: color-mix(in srgb, var(--surface-2) 85%, transparent);
    backdrop-filter: blur(3px);
    box-shadow: 0 1px 4px rgba(33, 29, 23, 0.22);
  }
  .visited-btn--card .visited-icon {
    width: 17px;
    height: 17px;
  }
  /* Icon-only on cards: the meaning is carried by the hover tip, not a label. */
  .visited-btn--card .visited-label {
    display: none;
  }
  .visited-btn--card[aria-pressed='true'] {
    background: var(--type-lake);
    color: var(--type-lake-text);
    border-color: var(--type-lake-text);
  }
  /* Bigger tap target on phones — 32px is fiddly under a finger. */
  @media (max-width: 760px) {
    .visited-btn--card {
      width: 44px;
      height: 44px;
    }
    .visited-btn--card .visited-icon {
      width: 22px;
      height: 22px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .visited-btn {
      transition: none;
    }
    .visited-btn:active {
      transform: none;
    }
    .visited-btn[aria-pressed='true'] .visited-icon {
      animation: none;
    }
  }
</style>
