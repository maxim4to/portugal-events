---
interface Props {
  placeId: string;
  variant?: 'card' | 'detail';
}
const { placeId, variant = 'detail' } = Astro.props;
---
<button
  type="button"
  class:list={['visited-btn', `visited-btn--${variant}`, { 'icon-tip': variant === 'card' }]}
  data-visited-id={placeId}
  data-tip="Был здесь"
  data-tip-on="Отмечено"
  aria-pressed="false"
  aria-label="Был здесь"
  hidden
>
  {/* Not visited: an open eye. Visited: the same eye filled, with a check for
      its pupil — the "on" state is toggled purely by aria-pressed (see CSS). */}
  <svg
    class="visited-icon"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M2 12s3.6-6.5 10-6.5S22 12 22 12s-3.6 6.5-10 6.5S2 12 2 12z" />
    <circle cx="12" cy="12" r="2.6" />
  </svg>
  <svg
    class="visited-icon-on"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    aria-hidden="true"
  >
    <path
      d="M2 12s3.6-6.5 10-6.5S22 12 22 12s-3.6 6.5-10 6.5S2 12 2 12z"
      fill="currentColor"
      stroke="currentColor"
      stroke-width="2"
      stroke-linejoin="round"
    />
    <path
      d="M9.1 12.2l2 2 3.8-4.2"
      fill="none"
      stroke="var(--surface-2)"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </svg>
  <span class="visited-label">Был здесь</span>
</button>

<style>
  .visited-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface-2);
    color: var(--text-secondary);
    font: inherit;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
  }
  .visited-btn:hover {
    border-color: var(--border-strong);
  }
  .visited-btn:active {
    transform: scale(0.94);
  }
  /* Pressed = visited: the eye fills in a clear "seen" green — mirrors how the
     favorite heart fills, so it reads at a glance instead of a faint tint. */
  .visited-btn[aria-pressed='true'] {
    color: var(--visited);
    border-color: var(--visited);
  }
  .visited-btn[aria-pressed='true'] .visited-icon-on {
    animation: toggle-pop 180ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .visited-icon,
  .visited-icon-on {
    flex: none;
  }
  /* Swap the outline eye for the filled eye-with-check on the pressed state. */
  .visited-icon-on {
    display: none;
  }
  .visited-btn[aria-pressed='true'] .visited-icon {
    display: none;
  }
  .visited-btn[aria-pressed='true'] .visited-icon-on {
    display: block;
  }

  /* Compact circular overlay for catalog cards. Mirrors FavoriteButton's card
     variant exactly — same shell, only the icon and pressed tint differ. */
  .visited-btn--card {
    width: 32px;
    height: 32px;
    padding: 0;
    justify-content: center;
    border-radius: var(--radius-pill);
    border: 0.5px solid var(--border);
    color: var(--text-primary);
    background: color-mix(in srgb, var(--surface-2) 85%, transparent);
    backdrop-filter: blur(3px);
    box-shadow: 0 1px 4px rgba(33, 29, 23, 0.22);
  }
  .visited-btn--card .visited-icon,
  .visited-btn--card .visited-icon-on {
    width: 18px;
    height: 18px;
  }
  /* Icon-only on cards: the meaning is carried by the hover tip, not a label. */
  .visited-btn--card .visited-label {
    display: none;
  }
  .visited-btn--card[aria-pressed='true'] {
    color: var(--visited);
    border-color: var(--visited);
  }
  /* Bigger tap target on phones — 32px is fiddly under a finger. */
  @media (max-width: 760px) {
    .visited-btn--card {
      width: 44px;
      height: 44px;
    }
    .visited-btn--card .visited-icon,
    .visited-btn--card .visited-icon-on {
      width: 22px;
      height: 22px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .visited-btn {
      transition: none;
    }
    .visited-btn:active {
      transform: none;
    }
    .visited-btn[aria-pressed='true'] .visited-icon-on {
      animation: none;
    }
  }
</style>
