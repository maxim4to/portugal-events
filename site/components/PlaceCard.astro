---
import type { Place } from '../../schema/index.ts';
import TypeBadge from './TypeBadge.astro';
import Icon from './Icon.astro';
import PhotoGallery from './PhotoGallery.astro';

interface Props {
  place: Place;
  href: string;
}
const { place, href } = Astro.props;
---
<a href={href} class="card place-card" data-card-link>
  <div class="cover">
    <PhotoGallery photos={place.photos} alt={place.name} variant="card" type={place.type} />
    <span class="badge-overlay">
      <TypeBadge type={place.type} />
    </span>
  </div>
  <div class="body">
    <h3>{place.name}</h3>
    <p class="desc">{place.description}</p>
    {place.freeWithResidency === true && (
      <span class="residency-pill">Бесплатно с ВНЖ</span>
    )}
    <div class="meta-row">
      <span><Icon name="clock" size={13} /> {place.driveMinutesFromLisbon} мин</span>
      <span><Icon name="hourglass" size={13} /> ~{place.visitDurationHours} ч</span>
      <span><Icon name="calendar" size={13} /> {place.bestSeason}</span>
    </div>
  </div>
</a>

<style>
  .place-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }
  .place-card:hover {
    border-color: var(--border-strong);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
    text-decoration: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .place-card:hover {
      transform: none;
    }
  }
  .cover {
    position: relative;
  }
  .badge-overlay {
    position: absolute;
    top: var(--space-2);
    left: var(--space-2);
    z-index: 4;
    pointer-events: none;
  }
  .body {
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }
  .body h3 {
    margin: 0;
  }
  .desc {
    margin: 0;
    font-size: 14px;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    /* Always reserve two lines so every card body is the same height. */
    min-height: 3.2em;
  }
  .residency-pill {
    align-self: flex-start;
    font-size: 12px;
    font-weight: 500;
    padding: 2px var(--space-2);
    border-radius: var(--radius-pill);
    background: var(--type-hike);
    color: var(--type-hike-text);
  }
  .meta-row {
    /* Push the meta to the bottom so cards of equal height align their footers. */
    margin-top: auto;
  }
  .meta-row span {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    white-space: nowrap;
  }
</style>
