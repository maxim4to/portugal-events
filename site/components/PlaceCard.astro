---
import type { Place } from '../../schema/index.ts';
import { TYPE_LABELS } from '../lib/labels.ts';
import Icon from './Icon.astro';
import PhotoGallery from './PhotoGallery.astro';

interface Props {
  place: Place;
  href: string;
}
const { place, href } = Astro.props;
const typeLabel = TYPE_LABELS[place.type] ?? place.type;
---
<a href={href} class="card place-card" data-card-link>
  <div class="cover">
    <PhotoGallery photos={place.photos} alt={place.name} variant="card" type={place.type} />
  </div>
  <div class="body">
    <span class="kicker type-kicker">
      <span class="type-dot" style={`background: var(--type-${place.type}-text);`} aria-hidden="true"></span>
      {typeLabel}
    </span>
    <h3>{place.name}</h3>
    <p class="desc">{place.description}</p>
    {place.freeWithResidency === true && (
      <span class="residency-pill">Бесплатно с ВНЖ</span>
    )}
    <div class="meta-row">
      <span><Icon name="clock" size={12} /> {place.driveMinutesFromLisbon} мин</span>
      <span><Icon name="hourglass" size={12} /> ~{place.visitDurationHours} ч</span>
      <span><Icon name="calendar" size={12} /> {place.bestSeason}</span>
    </div>
  </div>
</a>

<style>
  .place-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }
  .place-card:hover {
    border-color: var(--border-strong);
    box-shadow: 0 10px 30px rgba(33, 29, 23, 0.14);
    transform: translateY(-3px);
    text-decoration: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .place-card:hover {
      transform: none;
    }
  }
  .cover {
    position: relative;
  }
  .body {
    padding: var(--space-3) var(--space-3) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }
  .type-kicker {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .type-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex: none;
  }
  .body h3 {
    margin: 0;
    font-size: 19px;
    transition: color 0.15s ease;
  }
  .place-card:hover h3 {
    color: var(--accent);
  }
  .desc {
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    /* Always reserve two lines so every card body is the same height. */
    min-height: 3em;
  }
  .residency-pill {
    align-self: flex-start;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px var(--space-2);
    border-radius: var(--radius);
    background: var(--type-hike);
    color: var(--type-hike-text);
  }
  .meta-row {
    /* Push the meta to the bottom so cards of equal height align their footers. */
    margin-top: auto;
    padding-top: var(--space-2);
    border-top: 0.5px solid var(--border);
  }
  .meta-row span {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    white-space: nowrap;
  }
  /* Drop the "·" separators on cards: when the three facts wrap on a narrow
     card the leading dot would dangle at the start of the next line. Spacing
     alone separates them, and each fact stays whole (nowrap above). */
  .meta-row > * + *::before {
    content: none;
  }
  .meta-row {
    column-gap: var(--space-4);
    row-gap: var(--space-1);
  }
</style>
