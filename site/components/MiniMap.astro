---
interface Props {
  lat: number;
  lon: number;
  name: string;
}
const { lat, lon, name } = Astro.props;
---
<div class="minimap" data-lat={lat} data-lon={lon} data-name={name}></div>

<style>
  /* Full-column-width square: the point is shown in context relative to Lisbon. */
  .minimap {
    width: 100%;
    aspect-ratio: 1 / 1;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  /* Scoped container bg so tiles load onto a token-aware surface (dark mode).
     Global Leaflet popup/control overrides already live in the catalog. */
  .minimap :global(.leaflet-container) {
    background: var(--surface-1);
    font: inherit;
  }
  /* Touch screens: reserve one-finger vertical drags for page scroll; the JS
     disables one-finger map dragging so only two-finger gestures pan/zoom. */
  @media (pointer: coarse) {
    .minimap :global(.leaflet-container) {
      touch-action: pan-y;
    }
  }
  /* Map overlays sit on always-light OSM tiles, so they use a fixed, saturated
     colour + white halo instead of the theme accent (which goes pale-blue in
     dark mode and washes out against the tiles). */
  .minimap {
    --map-accent: #d1341f;
    --map-halo: #ffffff;
  }
  .minimap :global(.place-pin) {
    color: var(--map-accent);
  }
  .minimap :global(.place-pin svg) {
    display: block;
    /* White outline + soft shadow so the pin reads on any tile. */
    filter: drop-shadow(0 0 1px var(--map-halo))
      drop-shadow(0 0 1px var(--map-halo)) drop-shadow(0 2px 3px rgba(0, 0, 0, 0.45));
  }
  /* Small editorial label for the Lisbon anchor (no full pin, just context). */
  .minimap :global(.lisbon-tip) {
    background: var(--surface-2);
    color: var(--text-primary);
    border: 0.5px solid var(--border-strong);
    border-radius: var(--radius);
    box-shadow: 0 2px 8px rgba(33, 29, 23, 0.18);
    padding: 2px 6px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .minimap :global(.lisbon-tip::before) {
    display: none;
  }
  /* Label for the point of interest — same editorial chip as Lisbon, but tinted
     to the map accent so it reads as the primary marker. */
  .minimap :global(.place-tip) {
    background: var(--surface-2);
    color: var(--map-accent);
    border: 0.5px solid var(--map-accent);
    border-radius: var(--radius);
    box-shadow: 0 2px 8px rgba(33, 29, 23, 0.22);
    padding: 2px 7px;
    font-size: 11px;
    font-weight: 700;
    max-width: 160px;
    white-space: normal;
    text-align: center;
  }
  .minimap :global(.place-tip::before) {
    display: none;
  }
  /* Route + connector colours via CSS (CSS stroke/fill resolve tokens and win
     over Leaflet's presentation attributes). */
  .minimap :global(.route-line) {
    stroke: var(--map-accent);
    stroke-linejoin: round;
    stroke-linecap: round;
    fill: none;
  }
  /* White casing drawn under the route so it separates from the tiles. */
  .minimap :global(.route-casing) {
    stroke: var(--map-halo);
    stroke-linejoin: round;
    stroke-linecap: round;
    fill: none;
  }
  .minimap :global(.route-line--dashed) {
    opacity: 0.9;
  }
  .minimap :global(.lisbon-dot) {
    stroke: var(--map-accent);
    stroke-width: 3;
    fill: var(--map-halo);
  }
</style>

<script>
  import 'leaflet/dist/leaflet.css';
  import L from 'leaflet';

  // Central Lisbon — the trips all start here (see project design doc).
  const LISBON = { lat: 38.7223, lon: -9.1393 };

  const el = document.querySelector<HTMLElement>('.minimap');
  if (el && !el.dataset.ready) {
    el.dataset.ready = '1';
    const lat = Number(el.dataset.lat);
    const lon = Number(el.dataset.lon);
    const name = el.dataset.name || '';

    const PIN_HTML =
      '<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C7.6 2 4 5.6 4 10c0 5.4 7 11.6 7.3 11.9a1 1 0 0 0 1.4 0C13 21.6 20 15.4 20 10c0-4.4-3.6-8-8-8Zm0 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z"/></svg>';
    const pinIcon = L.divIcon({
      className: 'place-pin',
      html: PIN_HTML,
      iconSize: [24, 24],
      iconAnchor: [12, 22],
      popupAnchor: [0, -20],
    });

    // On touch screens, one-finger drag should scroll the page, not pan the
    // map — only a two-finger gesture (Leaflet's touch-zoom, which also pans)
    // interacts with the map. Desktop mouse dragging is unaffected.
    const coarse = window.matchMedia('(pointer: coarse)').matches;
    const map = L.map(el, {
      scrollWheelZoom: false,
      dragging: !coarse,
    }).setView([lat, lon], 12);
    if (coarse) {
      // Let the browser own vertical scroll gestures; two-finger gestures still
      // reach Leaflet (which preventDefaults them) so pinch/pan work.
      el.style.touchAction = 'pan-y';
    }
    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap contributors',
      maxZoom: 19,
    }).addTo(map);

    // The destination pin (the only real pin on the map), labelled like the
    // Lisbon anchor so the point of interest is named on the map.
    L.marker([lat, lon], { icon: pinIcon, title: name })
      .addTo(map)
      .bindTooltip(name, {
        permanent: true,
        direction: 'top',
        className: 'place-tip',
        offset: [0, -22],
      });

    // A subtle Lisbon anchor so the destination reads relative to it — a small
    // dot + label rather than a competing pin.
    L.circleMarker([LISBON.lat, LISBON.lon], {
      radius: 5,
      weight: 2,
      fillOpacity: 1,
      className: 'lisbon-dot',
    })
      .addTo(map)
      .bindTooltip('Лиссабон', {
        permanent: true,
        direction: 'top',
        className: 'lisbon-tip',
        offset: [0, -6],
      });

    // Frame both Lisbon and the destination; refined once a route is drawn.
    const bothBounds = L.latLngBounds([
      [LISBON.lat, LISBON.lon],
      [lat, lon],
    ]);
    map.fitBounds(bothBounds, { padding: [36, 36] });

    // Try to draw the actual driving route (OSRM demo). If anything fails, the
    // straight-line framing above already shows the point relative to Lisbon.
    const url =
      `https://router.project-osrm.org/route/v1/driving/` +
      `${LISBON.lon},${LISBON.lat};${lon},${lat}` +
      `?overview=full&geometries=geojson`;

    fetch(url)
      .then((r) => (r.ok ? r.json() : Promise.reject(new Error('route http ' + r.status))))
      .then((data) => {
        const geo = data?.routes?.[0]?.geometry;
        if (!geo || geo.type !== 'LineString') throw new Error('no route geometry');
        // White casing first, then the coloured route on top, so the line
        // stays legible over any map tiles.
        L.geoJSON(geo, {
          style: { weight: 8, opacity: 1, className: 'route-casing' },
        }).addTo(map);
        const line = L.geoJSON(geo, {
          style: { weight: 4, opacity: 1, className: 'route-line' },
        }).addTo(map);
        map.fitBounds(line.getBounds(), { padding: [30, 30] });
      })
      .catch(() => {
        // Fallback: a faint straight connector so the direction is still legible.
        L.polyline(
          [
            [LISBON.lat, LISBON.lon],
            [lat, lon],
          ],
          { weight: 3, dashArray: '6 7', className: 'route-line route-line--dashed' },
        ).addTo(map);
        map.fitBounds(bothBounds, { padding: [36, 36] });
      });
  }
</script>
