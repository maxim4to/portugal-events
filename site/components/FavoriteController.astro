---
// Client controller for the per-user "favorites" feature. Include once on any
// page that renders FavoriteButton(s) or the favorites filter. State lives in
// Firebase Realtime Database under users/<uid>/favorites (see lib/favorites.ts),
// so favorites follow the signed-in user across devices. It:
//  - hides the favorite buttons + favorites filter when Firebase is unconfigured
//  - reveals the favorites filter only while signed in (a guest has none)
//  - reflects the saved set onto every .favorite-btn and [data-place-card]
//  - keeps [data-fav-count] badges in sync with the number of favorites
//  - toggles on click; a click while signed out opens Google sign-in and
//    replays the toggle after (guarding against the enclosing card <a>)
//  - dispatches `favorites:changed` so an explorer can re-run its filter
---
<script>
  import {
    subscribeFavorites,
    setFavorite,
    isConfigured,
  } from '../lib/favorites.ts';
  import { onAuthChange, signInWithGoogle } from '../lib/auth.ts';

  const buttons = Array.from(
    document.querySelectorAll<HTMLButtonElement>('.favorite-btn'),
  );
  const countEls = Array.from(
    document.querySelectorAll<HTMLElement>('[data-fav-count]'),
  );
  // The favorites filter pill in the catalog toolbar.
  const favFilters = Array.from(
    document.querySelectorAll<HTMLElement>('[data-favorites]'),
  );

  const reflect = (ids: Set<string>) => {
    for (const btn of buttons) {
      const id = btn.dataset.favoriteId!;
      const on = ids.has(id);
      btn.setAttribute('aria-pressed', on ? 'true' : 'false');
      btn.setAttribute('aria-label', on ? 'Убрать из избранного' : 'В избранное');
      const label = btn.querySelector('.favorite-label');
      if (label) label.textContent = on ? 'В избранном' : 'В избранное';
    }
    // Reflect onto catalog card wrappers so the explorer filter can read it.
    document.querySelectorAll<HTMLElement>('[data-place-card]').forEach((wrap) => {
      const id = wrap.dataset.id!;
      wrap.dataset.favorite = ids.has(id) ? 'true' : 'false';
    });
    countEls.forEach((el) => {
      el.textContent = ids.size ? String(ids.size) : '';
    });
    document.dispatchEvent(new CustomEvent('favorites:changed'));
  };

  if (!isConfigured()) {
    // Inert: hide the toggles and the favorites filter entirely.
    buttons.forEach((btn) => (btn.hidden = true));
    favFilters.forEach((el) => (el.hidden = true));
  } else {
    let loggedIn = false;
    // A toggle attempted while signed out, replayed once sign-in succeeds.
    let pending: { id: string; on: boolean } | null = null;

    subscribeFavorites(reflect);

    // Reveal the favorites filter only while signed in; replay a pending toggle.
    onAuthChange((user) => {
      loggedIn = !!user;
      favFilters.forEach((el) => (el.hidden = !loggedIn));
      if (loggedIn && pending) {
        const p = pending;
        pending = null;
        void setFavorite(p.id, p.on);
      }
    });

    buttons.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        // Card buttons live inside an <a>; never navigate.
        e.preventDefault();
        e.stopPropagation();
        const id = btn.dataset.favoriteId!;
        const next = btn.getAttribute('aria-pressed') !== 'true';
        if (!loggedIn) {
          pending = { id, on: next };
          void signInWithGoogle();
          return;
        }
        // Optimistic reflect; the subscription will confirm/correct.
        btn.setAttribute('aria-pressed', next ? 'true' : 'false');
        void setFavorite(id, next);
      });
    });
  }
</script>
