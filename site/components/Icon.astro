---
// Tiny inline-SVG icon set. Keep this under ~10 icons; prefer reuse.
// All icons are 24x24 viewBox, stroke-based, currentColor.
interface Props {
  name:
    | 'sun'
    | 'moon'
    | 'clock'
    | 'hourglass'
    | 'calendar'
    | 'chevron-left'
    | 'chevron-right'
    | 'search'
    | 'sort'
    | 'arrow-left'
    | 'heart';
  size?: number;
  class?: string;
}
const { name, size = 16, class: className } = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  class={className}
>
  {name === 'sun' && (
    <>
      <circle cx="12" cy="12" r="4" />
      <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
    </>
  )}
  {name === 'moon' && (
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
  )}
  {name === 'clock' && (
    <>
      <circle cx="12" cy="12" r="9" />
      <path d="M12 7v5l3 2" />
    </>
  )}
  {name === 'hourglass' && (
    <>
      <path d="M6 3h12M6 21h12" />
      <path d="M7 3c0 4 4 5 5 7 1-2 5-3 5-7M7 21c0-4 4-5 5-7 1 2 5 3 5 7" />
    </>
  )}
  {name === 'calendar' && (
    <>
      <rect x="3" y="4" width="18" height="17" rx="2" />
      <path d="M3 9h18M8 2v4M16 2v4" />
    </>
  )}
  {name === 'chevron-left' && <path d="M15 18l-6-6 6-6" />}
  {name === 'chevron-right' && <path d="M9 18l6-6-6-6" />}
  {name === 'search' && (
    <>
      <circle cx="11" cy="11" r="7" />
      <path d="M21 21l-4.3-4.3" />
    </>
  )}
  {name === 'sort' && <path d="M8 6h13M8 12h9M8 18h5M3 6l2-2 2 2M5 4v16" />}
  {name === 'arrow-left' && <path d="M19 12H5M11 18l-6-6 6-6" />}
  {name === 'heart' && (
    <path d="M12 20s-7-4.6-9.3-9A4.9 4.9 0 0 1 12 6a4.9 4.9 0 0 1 9.3 5C19 15.4 12 20 12 20z" />
  )}
</svg>
