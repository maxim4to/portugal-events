---
import type { City, Event } from '../../schema/index.ts';
import type { MapPoint } from '../lib/mapExplorer.ts';
import MapShell from './MapShell.astro';
import Icon from './Icon.astro';
import { EVENT_TYPE_LABELS } from '../lib/labels.ts';
import { formatDateRu } from '../lib/dates.ts';
import { imageThumb } from '../lib/imgProxy.ts';
import { buildCityIndex, driveTimeFromLisbon } from '../lib/eventGeo.ts';

interface Props {
  events: Event[];
  points: MapPoint[];
  hrefBase: string;
  cities: City[];
}
const { events, points, hrefBase, cities } = Astro.props;
const cityIndex = buildCityIndex(cities);

const MONTHS_NOMINATIVE = [
  'Январь', 'Февраль', 'Март', 'Апрель', 'Май', 'Июнь',
  'Июль', 'Август', 'Сентябрь', 'Октябрь', 'Ноябрь', 'Декабрь',
];
function monthLabel(key: string): string {
  const [year, month] = key.split('-');
  return `${MONTHS_NOMINATIVE[Number(month) - 1] ?? month} ${year}`;
}

const todayISO = new Date().toISOString().slice(0, 10);
const ongoing = events
  .filter((e) => e.dateStart < todayISO)
  .sort((a, b) => a.dateEnd.localeCompare(b.dateEnd));
const future = events.filter((e) => e.dateStart >= todayISO);

const groups: { key: string; label: string; events: Event[] }[] = [];
if (ongoing.length > 0) groups.push({ key: 'ongoing', label: 'Сейчас идёт', events: ongoing });
for (const event of future) {
  const key = event.dateStart.slice(0, 7);
  const last = groups[groups.length - 1];
  if (last && last.key === key) last.events.push(event);
  else groups.push({ key, label: monthLabel(key), events: [event] });
}

function dateLabel(e: Event): string {
  return e.dateStart === e.dateEnd
    ? formatDateRu(e.dateStart)
    : `${formatDateRu(e.dateStart)} – ${formatDateRu(e.dateEnd)}`;
}

// Filter option sets, derived from the events actually present.
const presentTypes = [...new Set(events.map((e) => e.type))]
  .map((t) => [t, EVENT_TYPE_LABELS[t] ?? 'Событие'] as const)
  .sort((a, b) => a[1].localeCompare(b[1], 'ru'));
const presentCities = [...new Set(events.map((e) => e.city))].sort((a, b) =>
  a.localeCompare(b, 'ru'),
);
---
<MapShell kind="events" detailPrefix="/events/" hrefBase={hrefBase} mapId="events-map" points={points}>
  <div class="event-filters" slot="filters">
    <label class="search" aria-label="Поиск по названию, городу или площадке">
      <span class="search-icon" aria-hidden="true"><Icon name="search" size={16} /></span>
      <input
        type="search"
        class="search-input"
        data-filter="query"
        placeholder="Поиск события"
        autocomplete="off"
      />
    </label>

    {presentTypes.length > 1 && (
      <div class="fgroup" data-fgroup="type">
        <button type="button" class="fgroup-summary" data-fgroup-toggle aria-expanded="false">
          <span class="flabel">Тип</span><span class="fcount" data-fcount></span>
        </button>
        <div class="fgroup-menu">
          {presentTypes.map(([key, label]) => (
            <button type="button" class="chip" data-type={key} aria-pressed="false">{label}</button>
          ))}
        </div>
      </div>
    )}

    {presentCities.length > 1 && (
      <div class="fgroup" data-fgroup="city">
        <button type="button" class="fgroup-summary" data-fgroup-toggle aria-expanded="false">
          <span class="flabel">Город</span><span class="fcount" data-fcount></span>
        </button>
        <div class="fgroup-menu">
          {presentCities.map((c) => (
            <button type="button" class="chip" data-city={c} aria-pressed="false">{c}</button>
          ))}
        </div>
      </div>
    )}

    <button type="button" class="reset-btn" data-reset hidden>Сбросить</button>
  </div>

  <div class="event-list" slot="list">
    {events.length === 0 ? (
      <p class="muted">Будущих событий пока нет.</p>
    ) : (
      groups.map((group) => (
        <section class="month" data-group>
          <h2 data-group-label>{group.label}</h2>
          <div class="grid-cards">
            {group.events.map((event) => (
              <a
                class="card event-card"
                href={`${hrefBase}/events/${event.id}/`}
                data-item-card
                data-id={event.id}
                data-name={`${event.title} ${event.city} ${event.venue}`}
                data-type={event.type}
                data-city={event.city}
                data-card-link
              >
                <div class="cover">
                  {event.image && (
                    <img
                      src={imageThumb(event.image, 480, 300)}
                      data-fallback={event.image}
                      alt={event.title}
                      loading="lazy"
                      decoding="async"
                      referrerpolicy="no-referrer"
                      onerror="this.onerror=null;this.src=this.dataset.fallback"
                    />
                  )}
                  <span class="badge event-badge">{EVENT_TYPE_LABELS[event.type] ?? 'Событие'}</span>
                </div>
                <div class="body">
                  <span class="date muted">{dateLabel(event)}</span>
                  <h3>{event.title}</h3>
                  <p class="place muted">{event.city}, {event.venue}</p>
                  {driveTimeFromLisbon(event, cityIndex) && (
                    <p class="drive-time muted">{driveTimeFromLisbon(event, cityIndex)}</p>
                  )}
                  {event.price && <p class="price">{event.price}</p>}
                </div>
              </a>
            ))}
          </div>
        </section>
      ))
    )}
  </div>
</MapShell>

<style>
  .event-filters {
    flex: 1 1 100%;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .month {
    margin-bottom: var(--space-5);
  }
  .event-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }
  .event-card:hover {
    border-color: var(--border-strong);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
    text-decoration: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .event-card:hover {
      transform: none;
    }
  }
  .cover {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--accent-bg);
  }
  .cover img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .event-badge {
    position: absolute;
    top: var(--space-2);
    left: var(--space-2);
    z-index: 4;
    background: var(--accent-bg);
    color: var(--accent-text);
  }
  .body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    flex: 1;
  }
  .date {
    font-size: 13px;
  }
  .body h3 {
    margin: 0;
  }
  .place,
  .price,
  .drive-time {
    margin: 0;
    font-size: 14px;
    color: var(--text-secondary);
  }

  @media (max-width: 760px) {
    .event-filters .search {
      flex: 1 1 100%;
      order: -1;
      min-width: 0;
    }
  }
</style>

<script>
  import { initMapExplorer } from '../lib/mapExplorer.ts';
  import { initFilterGroups, setGroupCount } from '../lib/filterGroups.ts';

  const root = document.querySelector<HTMLElement>('[data-explorer]');
  if (root) {
    const searchInput = root.querySelector<HTMLInputElement>('[data-filter="query"]');
    const typeChips = Array.from(root.querySelectorAll<HTMLButtonElement>('.chip[data-type]'));
    const cityChips = Array.from(root.querySelectorAll<HTMLButtonElement>('.chip[data-city]'));
    const resetButtons = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-reset]'));

    const isOn = (el: Element | null) => el?.getAttribute('aria-pressed') === 'true';
    const press = (el: Element, on: boolean) =>
      el.setAttribute('aria-pressed', on ? 'true' : 'false');

    const state = () => ({
      query: (searchInput?.value || '').trim().toLowerCase(),
      types: typeChips.filter(isOn).map((c) => c.dataset.type!),
      city: cityChips.find(isOn)?.dataset.city ?? '',
    });

    const matches = (el: HTMLElement) => {
      const s = state();
      if (s.query && !(el.dataset.name || '').toLowerCase().includes(s.query)) return false;
      if (s.types.length && !s.types.includes(el.dataset.type || '')) return false;
      if (s.city && el.dataset.city !== s.city) return false;
      return true;
    };

    const explorer = initMapExplorer(root, { matches });
    initFilterGroups(root);

    function anyActive() {
      const s = state();
      return Boolean(s.query || s.types.length || s.city);
    }

    function writeUrl() {
      const s = state();
      const params = new URLSearchParams();
      if (searchInput?.value.trim()) params.set('q', searchInput.value.trim());
      if (s.types.length) params.set('type', s.types.join(','));
      if (s.city) params.set('city', s.city);
      const qs = params.toString();
      history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
    }

    function onFilterChange() {
      const s = state();
      setGroupCount(root!, 'type', s.types.length);
      setGroupCount(root!, 'city', s.city ? 1 : 0);
      resetButtons.forEach((b) => (b.hidden = !anyActive()));
      writeUrl();
      explorer.rerender();
    }

    typeChips.forEach((c) =>
      c.addEventListener('click', () => {
        press(c, !isOn(c));
        onFilterChange();
      }),
    );
    cityChips.forEach((c) =>
      c.addEventListener('click', () => {
        const was = isOn(c);
        cityChips.forEach((o) => press(o, false));
        press(c, !was);
        onFilterChange();
      }),
    );
    searchInput?.addEventListener('input', onFilterChange);
    resetButtons.forEach((b) =>
      b.addEventListener('click', () => {
        [...typeChips, ...cityChips].forEach((c) => press(c, false));
        if (searchInput) searchInput.value = '';
        onFilterChange();
      }),
    );

    // Restore from URL.
    const params = new URLSearchParams(location.search);
    if (searchInput && params.get('q')) searchInput.value = params.get('q')!;
    const preTypes = new Set((params.get('type') || '').split(',').map((s) => s.trim()).filter(Boolean));
    typeChips.forEach((c) => {
      if (preTypes.has(c.dataset.type!)) press(c, true);
    });
    const preCity = params.get('city');
    if (preCity) {
      const chip = cityChips.find((c) => c.dataset.city === preCity);
      if (chip) press(chip, true);
    }

    onFilterChange();
  }
</script>
