---
import type { Event } from '../../schema/index.ts';
import { EVENT_TYPE_LABELS } from '../lib/labels.ts';
import { formatDateRu } from '../lib/dates.ts';

interface Props {
  event: Event;
}
const { event } = Astro.props;

const dateLabel =
  event.dateStart === event.dateEnd
    ? formatDateRu(event.dateStart)
    : `${formatDateRu(event.dateStart)} – ${formatDateRu(event.dateEnd)}`;
---
<div class="card event-card">
  <div class="top-row">
    <span class="badge event-badge">{EVENT_TYPE_LABELS[event.type] ?? 'Событие'}</span>
    <span class="date muted">{dateLabel}</span>
  </div>
  <h3>{event.title}</h3>
  <p class="place muted">{event.city}, {event.venue}</p>
  {event.price && <p class="price">{event.price}</p>}
  <a class="btn" href={event.url} target="_blank" rel="noopener">Подробнее</a>
</div>

<style>
  .event-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
  }
  .top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }
  .event-badge {
    background: var(--accent-bg);
    color: var(--accent-text);
  }
  .date {
    font-size: 13px;
  }
  .event-card h3 {
    margin: 0;
  }
  .place {
    margin: 0;
    font-size: 14px;
    color: var(--text-secondary);
  }
  .price {
    margin: 0;
    font-size: 14px;
    color: var(--text-secondary);
  }
  .event-card .btn {
    margin-top: var(--space-2);
    align-self: flex-start;
  }
</style>
