---
import type { City, Event } from '../../schema/index.ts';
import { EVENT_TYPE_LABELS } from '../lib/labels.ts';
import { formatDateRu } from '../lib/dates.ts';
import { imageThumb } from '../lib/imgProxy.ts';
import { buildCityIndex, driveTimeFromLisbon } from '../lib/eventGeo.ts';

interface Props {
  event: Event;
  cities: City[];
}
const { event, cities } = Astro.props;
const driveTime = driveTimeFromLisbon(event, buildCityIndex(cities));

const dateLabel =
  event.dateStart === event.dateEnd
    ? formatDateRu(event.dateStart)
    : `${formatDateRu(event.dateStart)} – ${formatDateRu(event.dateEnd)}`;
---
<div class="card event-card">
  <div class="cover">
    {event.image && (
      <img
        src={imageThumb(event.image, 480, 300)}
        data-fallback={event.image}
        alt={event.title}
        loading="lazy"
        decoding="async"
        referrerpolicy="no-referrer"
        onerror="this.onerror=null;this.src=this.dataset.fallback"
      />
    )}
    <span class="badge event-badge">{EVENT_TYPE_LABELS[event.type] ?? 'Событие'}</span>
  </div>
  <div class="body">
    <span class="date muted">{dateLabel}</span>
    <h3>{event.title}</h3>
    <p class="place muted">{event.city}, {event.venue}</p>
    {driveTime && <p class="drive-time muted">{driveTime}</p>}
    {event.price && <p class="price">{event.price}</p>}
    <a class="btn" href={event.url} target="_blank" rel="noopener">Подробнее</a>
  </div>
</div>

<style>
  .event-card {
    display: flex;
    flex-direction: column;
  }
  .cover {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    /* Fallback tint always present; a loaded img covers it, a broken img reveals it. */
    background: var(--accent-bg);
  }
  .cover img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .event-badge {
    position: absolute;
    top: var(--space-2);
    left: var(--space-2);
    z-index: 4;
    background: var(--accent-bg);
    color: var(--accent-text);
  }
  .body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    flex: 1;
  }
  .date {
    font-size: 13px;
  }
  .body h3 {
    margin: 0;
  }
  .place,
  .drive-time {
    margin: 0;
    font-size: 14px;
    color: var(--text-secondary);
  }
  .price {
    margin: 0;
    font-size: 14px;
    color: var(--text-secondary);
  }
  .event-card .btn {
    margin-top: var(--space-2);
    align-self: flex-start;
  }
</style>
