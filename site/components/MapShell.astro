---
import type { MapPoint } from '../lib/mapExplorer.ts';

interface Props {
  kind: 'places' | 'events';
  detailPrefix: string;
  hrefBase: string;
  mapId: string;
  points: MapPoint[];
  /** Hold the catalog hidden until the signed-in profile + its saved sets load,
      so the list paints once (already ordered) instead of reflowing. */
  awaitUser?: boolean;
}
const { kind, detailPrefix, hrefBase, mapId, points, awaitUser = false } = Astro.props;
---
<section
  class="explorer-root"
  data-explorer
  data-kind={kind}
  data-detail-prefix={detailPrefix}
  data-href-base={hrefBase}
  data-user-loading={awaitUser ? '' : undefined}
>
  <div class="filter-bar-top">
    <slot name="filters" />
    <div class="toolbar">
      <slot name="toolbar" />
    </div>
  </div>

  <div class="map-explorer">
    <div class="pane pane-list">
      <div class="list-scroll" data-list-scroll>
        <slot name="list" />
        <div class="empty" data-empty hidden>
          <p class="empty-title">Ничего не найдено</p>
          <p class="empty-hint">Попробуйте изменить фильтры или подвинуть карту.</p>
          <button type="button" class="btn empty-reset" data-reset>Сбросить фильтры</button>
        </div>
      </div>
    </div>

    <div class="pane pane-map">
      <div class="map" id={mapId} data-map></div>
    </div>
  </div>

  {/* Placed at the end of the flow (not up in the toolbar) so that if a frame
      ever paints before the stylesheet pins it to `position: fixed`, it appears
      at the bottom of the list — off-screen — instead of flashing at the top. */}
  <div class="view-toggle" role="group" aria-label="Вид">
    <button type="button" class="btn view-btn" data-view="list" aria-pressed="true">Список</button>
    <button type="button" class="btn view-btn" data-view="map" aria-pressed="false">Карта</button>
  </div>

  <script type="application/json" data-points set:html={JSON.stringify(points)}></script>

  {awaitUser && (
    <div class="catalog-loader" aria-hidden="true">
      <span class="catalog-spinner"></span>
    </div>
  )}
</section>

<style>
  .explorer-root {
    position: relative;
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
  }

  /* While waiting for the signed-in profile + saved sets, fade the content and
     show a centered spinner. Content stays laid out (opacity, not display:none)
     so the map still measures its pane. Revealed by removing the attribute
     (see lib/catalogReady.ts). */
  .explorer-root[data-user-loading] .filter-bar-top,
  .explorer-root[data-user-loading] .map-explorer,
  .explorer-root[data-user-loading] .view-toggle {
    opacity: 0;
    pointer-events: none;
  }
  .filter-bar-top,
  .map-explorer,
  .view-toggle {
    transition: opacity 0.2s ease;
  }
  .catalog-loader {
    display: none;
  }
  /* Fixed (not absolute): on mobile the explorer root is the full, page-tall
     scroll region, so an absolute overlay would center the spinner thousands of
     px down. Fixed keeps it in the middle of the viewport. */
  .explorer-root[data-user-loading] .catalog-loader {
    display: flex;
    position: fixed;
    inset: 0;
    z-index: 60;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  .catalog-spinner {
    width: 28px;
    height: 28px;
    border: 2.5px solid var(--border-strong);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: catalog-spin 0.7s linear infinite;
  }
  @keyframes catalog-spin {
    to {
      transform: rotate(360deg);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .catalog-spinner {
      animation-duration: 1.4s;
    }
  }

  /* Compact full-width filter bar above the two panes. Sits above the card
     action buttons (z-index 5) so its dropdowns are never occluded. */
  .filter-bar-top {
    position: relative;
    z-index: 40;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    padding: var(--space-2) 0 var(--space-3);
  }
  .toolbar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-left: auto;
  }
  .view-toggle {
    display: none;
    gap: var(--space-1);
  }
  .view-btn[aria-pressed='true'] {
    background: var(--accent-bg);
    color: var(--accent-text);
    border-color: var(--border-strong);
  }

  .map-explorer {
    flex: 1;
    min-height: 0;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    grid-template-rows: minmax(0, 1fr);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .pane {
    min-width: 0;
    min-height: 0;
  }
  .pane-list {
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--border-strong);
  }
  .list-scroll {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-3);
  }
  .empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-6) var(--space-4);
    text-align: center;
    color: var(--text-muted);
  }
  .empty[hidden] {
    display: none;
  }
  .empty-title {
    margin: 0;
    font-size: 16px;
    font-weight: 500;
    color: var(--text-secondary);
  }
  .empty-hint {
    margin: 0;
    font-size: 14px;
  }
  .empty-reset {
    margin-top: var(--space-2);
  }
  .pane-map {
    position: relative;
    z-index: 0;
  }
  .map {
    width: 100%;
    height: 100%;
  }

  /* Active states for list↔map sync. Covers both the places layout (a .card
     nested inside the [data-item-card] wrapper) and events (where the
     [data-item-card] element is itself the .card). */
  :global(.explorer-root [data-item-card].is-active),
  :global(.explorer-root [data-item-card].is-active .card) {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px var(--accent);
  }
  :global(.place-pin) {
    color: var(--accent);
  }
  :global(.place-pin svg) {
    display: block;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.35));
    transition: transform 0.12s ease;
    transform-origin: bottom center;
  }
  /* Highlight: scale the inner <svg>, not .place-pin itself — Leaflet owns the
     pin element's transform for positioning, so a transform there is ignored. */
  :global(.place-pin.pin-active) {
    color: var(--danger);
    z-index: 1000 !important;
  }
  :global(.place-pin.pin-active svg) {
    transform: scale(1.5);
  }

  /* Visited places: a dimmer pin so they recede behind unseen ones. Full
     opacity again while highlighted (hovered/selected). */
  :global(.place-pin--visited) {
    opacity: 0.4;
  }
  :global(.place-pin--visited.pin-active) {
    opacity: 1;
  }

  /* Favorites: a heart, always in the danger red (the pin-active red then just
     scales it). Highlighted state scales a touch more with a stronger shadow so
     a selected favorite stands out on the map. */
  :global(.place-pin--favorite) {
    color: var(--danger);
  }
  :global(.place-pin--favorite.pin-active svg) {
    transform: scale(1.5);
    filter: drop-shadow(0 2px 5px rgba(0, 0, 0, 0.45));
  }

  /* Leaflet legibility with design tokens (esp. dark mode). */
  :global(.leaflet-container) {
    background: var(--surface-1);
    font: inherit;
  }
  :global(.leaflet-popup-content-wrapper),
  :global(.leaflet-popup-tip) {
    background: var(--surface-2);
    color: var(--text-primary);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.25);
  }
  :global(.leaflet-popup-content) {
    margin: var(--space-2) var(--space-3);
    font-size: 14px;
  }
  :global(.leaflet-popup-content a) {
    color: var(--accent);
    font-weight: 500;
  }

  /* --- Rich editorial pin popup (see lib/mapExplorer.popupHtml) --- */
  :global(.map-pop-popup .leaflet-popup-content-wrapper) {
    padding: 0;
    overflow: hidden;
    border: 0.5px solid var(--border-strong);
    border-radius: var(--radius-lg);
    box-shadow: 0 14px 36px rgba(33, 29, 23, 0.28);
  }
  /* Fixed width so every card is identical. Leaflet otherwise sets its own
     content width from the text's measured (nowrap) width; forcing `auto` here
     broke that, letting the popup shrink to a short title or stretch to a long
     line — hence the "floating" width. `!important` beats Leaflet's inline width. */
  :global(.map-pop-popup .leaflet-popup-content) {
    margin: 0;
    width: 240px !important;
    font-size: inherit;
  }
  /* Close button legible over the cover image. */
  :global(.map-pop-popup .leaflet-popup-close-button) {
    top: 6px;
    right: 6px;
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--surface-2) 85%, transparent);
    color: var(--text-primary);
    box-shadow: 0 1px 4px rgba(33, 29, 23, 0.28);
    font-size: 16px;
    line-height: 1;
  }
  :global(.map-pop-popup .leaflet-popup-close-button:hover) {
    background: var(--surface-2);
  }
  :global(.map-pop) {
    display: block;
    color: var(--text-primary);
    text-decoration: none;
  }
  :global(.map-pop:hover) {
    text-decoration: none;
  }
  :global(.map-pop-media) {
    display: block;
    aspect-ratio: 16 / 10;
    background: var(--accent-bg);
    overflow: hidden;
  }
  :global(.map-pop-media img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  :global(.map-pop-body) {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: var(--space-3);
  }
  :global(.map-pop-kicker) {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--editorial);
  }
  :global(.map-pop-title) {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 550;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--text-primary);
  }
  :global(.map-pop-meta) {
    font-size: 12px;
    color: var(--text-secondary);
  }
  :global(.map-pop-more) {
    margin-top: var(--space-1);
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--accent);
  }
  :global(.map-pop:hover .map-pop-more) {
    text-decoration: underline;
  }
  :global(.leaflet-bar a),
  :global(.leaflet-bar a:hover) {
    background: var(--surface-2);
    color: var(--text-primary);
    border-color: var(--border);
  }
  :global(.leaflet-control-attribution) {
    background: color-mix(in srgb, var(--surface-2) 80%, transparent);
    color: var(--text-muted);
  }
  :global(.leaflet-control-attribution a) {
    color: var(--accent);
  }

  /* Mobile: single column, toggle between list and map. */
  @media (max-width: 760px) {
    .map-explorer {
      grid-template-columns: 1fr;
    }
    .pane-map {
      display: none;
    }
    .explorer-root.show-map .pane-list {
      display: none;
    }
    .explorer-root.show-map .pane-map {
      display: block;
    }
    /* Leave room for the floating toggle so the last card isn't hidden. */
    .list-scroll {
      padding-bottom: 72px;
    }
    .toolbar {
      margin-left: 0;
    }

    /* List view: no frame, no inner scroll — the whole page scrolls (the
       viewport lock is lifted in Base.astro for this case). */
    .explorer-root:not(.show-map) .map-explorer {
      border: 0;
      border-radius: 0;
      overflow: visible;
    }
    .explorer-root:not(.show-map) .pane-list {
      border-right: 0;
    }
    /* All the side margin now comes from .main.wide (12px); drop the list's own
       horizontal padding so cards get the full width and align with the filter
       bar. Vertical padding (incl. the toggle clearance) is preserved. */
    .explorer-root:not(.show-map) .list-scroll {
      overflow: visible;
      padding-left: 0;
      padding-right: 0;
    }

    /* The filter bar floats over the scrolling list: sticky to the top, hidden
       on scroll-down and revealed on scroll-up (`.hide-filter-bar` is toggled
       by mapExplorer). Full-bleed background so content passes cleanly under. */
    .explorer-root:not(.show-map) .filter-bar-top {
      position: sticky;
      top: 0;
      /* Full-bleed to the screen edge, then re-pad to the 12px content margin so
         the bar's contents line up with the cards below it. */
      margin-left: calc(-1 * var(--space-3));
      margin-right: calc(-1 * var(--space-3));
      padding-left: var(--space-3);
      padding-right: var(--space-3);
      background: var(--surface-0);
      border-bottom: 0.5px solid var(--border);
      transition: transform 0.25s ease;
    }
    .explorer-root:not(.show-map).hide-filter-bar .filter-bar-top {
      transform: translateY(-100%);
    }
    /* Airbnb-style floating list/map switch, centered at the bottom. */
    .view-toggle {
      display: inline-flex;
      position: fixed;
      left: 50%;
      bottom: calc(var(--space-4) + env(safe-area-inset-bottom, 0px));
      transform: translateX(-50%);
      z-index: 50;
      gap: 0;
      padding: 4px;
      background: var(--surface-2);
      border: 0.5px solid var(--border-strong);
      border-radius: var(--radius-pill);
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.22);
    }
    .view-btn {
      border: 0;
      border-radius: var(--radius-pill);
      padding: var(--space-2) var(--space-4);
    }
  }
</style>
