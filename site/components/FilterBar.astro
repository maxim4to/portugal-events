---
import { TYPE_LABELS } from '../lib/labels.ts';

interface Props {
  regions: string[];
  tags: string[];
}
const { regions, tags } = Astro.props;
const typeEntries = Object.entries(TYPE_LABELS);
---
<div class="filter-bar">
  <div class="row search-row">
    <input
      type="search"
      class="search-input"
      data-filter="query"
      placeholder="Поиск по названию или региону"
      aria-label="Поиск по названию или региону"
    />
  </div>

  <div class="row chips-row" role="group" aria-label="Типы мест">
    {typeEntries.map(([key, label]) => (
      <button type="button" class="chip" data-type={key} aria-pressed="false">{label}</button>
    ))}
  </div>

  <div class="row controls-row">
    <label class="control">
      <span class="control-label">Регион</span>
      <select class="select" data-filter="region" aria-label="Регион">
        <option value="">Все регионы</option>
        {regions.map((r) => (
          <option value={r}>{r}</option>
        ))}
      </select>
    </label>

    <label class="control range-control">
      <span class="control-label">Время в пути</span>
      <span class="range-wrap">
        <input
          type="range"
          data-filter="maxDrive"
          min="20"
          max="240"
          step="10"
          value="240"
          aria-label="Максимальное время в пути"
        />
        <span class="range-out" data-out="maxDrive">любое время</span>
      </span>
    </label>

    <details class="control tags-control">
      <summary class="select summary">Теги</summary>
      <div class="tags-menu">
        {tags.map((t) => (
          <label class="tag-item"><input type="checkbox" data-tag={t} /> {t}</label>
        ))}
      </div>
    </details>
  </div>
</div>

<style>
  .filter-bar {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }
  .row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }
  .search-input {
    width: 100%;
    max-width: 420px;
    padding: var(--space-2) var(--space-3);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface-2);
    color: var(--text-primary);
    font: inherit;
  }
  .search-input::placeholder {
    color: var(--text-muted);
  }
  .controls-row {
    gap: var(--space-4);
  }
  .control {
    display: inline-flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .control-label {
    font-size: 12px;
    color: var(--text-muted);
  }
  .select,
  .summary {
    padding: var(--space-2) var(--space-3);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface-2);
    color: var(--text-primary);
    font: inherit;
    cursor: pointer;
  }
  .summary {
    list-style: none;
    user-select: none;
  }
  .summary::-webkit-details-marker {
    display: none;
  }
  .range-wrap {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    height: 34px;
  }
  .range-control input[type='range'] {
    accent-color: var(--accent);
    width: 160px;
  }
  .range-out {
    font-size: 13px;
    color: var(--text-secondary);
    min-width: 92px;
  }
  .tags-control {
    position: relative;
  }
  .tags-menu {
    position: absolute;
    z-index: 500;
    margin-top: var(--space-1);
    max-height: 260px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-3);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface-2);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    min-width: 200px;
  }
  .tag-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 14px;
    color: var(--text-secondary);
    cursor: pointer;
  }
  .tag-item input {
    accent-color: var(--accent);
  }
</style>
