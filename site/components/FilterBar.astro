---
import { TYPE_LABELS } from '../lib/labels.ts';
import Icon from './Icon.astro';

interface Props {
  regions: string[];
  tags: string[];
}
const { regions, tags } = Astro.props;
const typeEntries = Object.entries(TYPE_LABELS);
const drivePresets = [
  { value: 60, label: 'до 1 ч' },
  { value: 120, label: 'до 2 ч' },
  { value: 180, label: 'до 3 ч' },
  { value: 240, label: 'любое' },
];
---
<div class="filter-bar">
  <button type="button" class="fav-toggle" data-favorites aria-pressed="false" aria-label="Показать избранное" hidden>
    <span class="fav-heart" aria-hidden="true"><Icon name="heart" size={15} /></span>
    <span class="flabel">Избранное</span><span class="fcount" data-fav-count></span>
  </button>

  <div class="fgroup" data-fgroup="type">
    <button type="button" class="fgroup-summary" data-fgroup-toggle aria-expanded="false">
      <span class="flabel">Тип</span><span class="fcount" data-fcount></span>
    </button>
    <div class="fgroup-menu">
      {typeEntries.map(([key, label]) => (
        <button type="button" class="chip" data-type={key} aria-pressed="false">{label}</button>
      ))}
    </div>
  </div>

  <div class="fgroup" data-fgroup="region">
    <button type="button" class="fgroup-summary" data-fgroup-toggle aria-expanded="false">
      <span class="flabel">Регион</span><span class="fcount" data-fcount></span>
    </button>
    <div class="fgroup-menu">
      {regions.map((r) => (
        <button type="button" class="chip" data-region={r} aria-pressed="false">{r}</button>
      ))}
    </div>
  </div>

  <div class="fgroup" data-fgroup="tags">
    <button type="button" class="fgroup-summary" data-fgroup-toggle aria-expanded="false">
      <span class="flabel">Теги</span><span class="fcount" data-fcount></span>
    </button>
    <div class="fgroup-menu">
      {tags.map((t) => (
        <button type="button" class="chip" data-tag={t} aria-pressed="false">{t}</button>
      ))}
    </div>
  </div>

  <div class="fgroup" data-fgroup="drive">
    <button type="button" class="fgroup-summary" data-fgroup-toggle aria-expanded="false">
      <span class="flabel">В пути</span><span class="fcount" data-fcount></span>
    </button>
    <div class="fgroup-menu">
      {drivePresets.map((p) => (
        <button
          type="button"
          class="chip"
          data-drive={p.value}
          aria-pressed={p.value === 240 ? 'true' : 'false'}
        >{p.label}</button>
      ))}
    </div>
  </div>

  <div class="fgroup" data-fgroup="more">
    <button type="button" class="fgroup-summary" data-fgroup-toggle aria-expanded="false">
      <span class="flabel">Ещё</span><span class="fcount" data-fcount></span>
    </button>
    <div class="fgroup-menu">
      <button type="button" class="chip" data-residency aria-pressed="false">Бесплатно с ВНЖ</button>
      <span class="visited-group" data-visited-control data-filter="visited" hidden>
        <button type="button" class="chip" data-visited-opt="visited" aria-pressed="false">Посещённые</button>
        <button type="button" class="chip" data-visited-opt="unvisited" aria-pressed="false">Непосещённые</button>
      </span>
    </div>
  </div>

  <button type="button" class="reset-btn" data-reset hidden>Сбросить</button>
</div>

<style>
  /* Shared pill/dropdown/search/reset primitives live in base.css. */
  .filter-bar {
    flex: 1 1 100%;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .visited-group {
    display: inline-flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .visited-group[hidden] {
    display: none;
  }

  /* Favorites toggle — a pill matching the filter groups, with a heart. */
  .fav-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    height: 36px;
    padding: 0 var(--space-3);
    border: 0.5px solid var(--border-strong);
    border-radius: var(--radius-pill);
    background: var(--surface-2);
    color: var(--text-primary);
    font: inherit;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, box-shadow 0.15s ease;
  }
  .fav-toggle:hover {
    border-color: var(--text-secondary);
  }
  .fav-toggle:focus-visible {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-bg);
  }
  .fav-heart {
    display: inline-flex;
    color: var(--text-secondary);
  }
  .fav-toggle[aria-pressed='true'] {
    border-color: var(--danger);
    background: color-mix(in srgb, var(--danger) 12%, var(--surface-2));
  }
  .fav-toggle[aria-pressed='true'] .fav-heart {
    color: var(--danger);
  }
  .fav-toggle[aria-pressed='true'] .fav-heart :global(svg path) {
    fill: var(--danger);
  }
  .fav-toggle .fcount {
    background: var(--danger);
  }
  /* Hidden until signed in (the FavoriteController toggles this). The explicit
     display above would otherwise win over the `hidden` attribute. */
  .fav-toggle[hidden] {
    display: none;
  }
</style>
