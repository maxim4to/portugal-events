---
import Icon from './Icon.astro';

const href = (p: string) => import.meta.env.BASE_URL.replace(/\/$/, '') + p;

const links = [
  { path: '/places/', label: 'Места' },
  { path: '/events/', label: 'Афиша' },
];

// Astro.url.pathname includes the base (e.g. /portugal-events/places/).
// Normalise both sides (strip trailing slash, treat empty as '/') and match by suffix.
const current = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (p: string) => {
  const target = href(p).replace(/\/$/, '') || '/';
  return current === target;
};
---
<header class="site-header">
  <div class="inner">
    <a href={href('/')} class="brand" aria-label="Португалия — на главную">
      <span class="brand-mark" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C7.6 2 4 5.6 4 10c0 5.4 7 11.6 7.3 11.9a1 1 0 0 0 1.4 0C13 21.6 20 15.4 20 10c0-4.4-3.6-8-8-8Zm0 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z"/>
        </svg>
      </span>
      <span class="brand-name">Португалия</span>
    </a>

    <nav class="nav" aria-label="Разделы">
      {links.map((l) => (
        <a
          href={href(l.path)}
          class:list={['nav-link', { active: isActive(l.path) }]}
          data-label={l.label}
          aria-current={isActive(l.path) ? 'page' : undefined}
        >
          <span class="nav-link-text">{l.label}</span>
        </a>
      ))}
    </nav>

    <div class="actions">
      <div class="auth" data-auth hidden>
        <button type="button" class="auth-signin" data-auth-signin hidden>Войти</button>
        <div class="auth-user" data-auth-user hidden>
          <img class="auth-avatar" data-auth-avatar alt="" width="28" height="28" referrerpolicy="no-referrer" />
          <button type="button" class="auth-signout" data-auth-signout>Выйти</button>
        </div>
      </div>
      <button class="icon-btn theme-toggle" id="theme-toggle" aria-label="Переключить тему">
        <span class="icon-sun"><Icon name="sun" size={18} /></span>
        <span class="icon-moon"><Icon name="moon" size={18} /></span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: var(--surface-2);
    border-bottom: 0.5px solid var(--border);
  }
  .inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-5);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    justify-self: start;
    color: var(--accent);
    font-weight: 500;
    font-size: 17px;
  }
  .brand:hover {
    text-decoration: none;
  }
  .brand-mark {
    display: inline-flex;
  }
  .brand-name {
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  /* Centered Airbnb-style tabs with an underline on the active one. */
  .nav {
    display: inline-flex;
    align-items: center;
    gap: var(--space-5);
    justify-self: center;
  }
  .nav-link {
    display: inline-grid;
    position: relative;
    padding: var(--space-2) 0;
    font-size: 15px;
    color: var(--text-secondary);
  }
  /* Reserve the bold (active) width so toggling weight never shifts neighbours. */
  .nav-link::after {
    content: attr(data-label);
    grid-area: 1 / 1;
    font-weight: 500;
    height: 0;
    visibility: hidden;
    pointer-events: none;
  }
  .nav-link-text {
    grid-area: 1 / 1;
  }
  .nav-link:hover {
    text-decoration: none;
    color: var(--text-primary);
  }
  .nav-link.active {
    color: var(--text-primary);
    font-weight: 500;
  }
  .nav-link.active::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 2px;
    border-radius: 2px;
    background: var(--text-primary);
  }

  .actions {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    justify-self: end;
  }

  /* Auth control — a pill matching the theme toggle. */
  .auth[hidden] {
    display: none;
  }
  .auth-signin {
    display: inline-flex;
    align-items: center;
    height: 40px;
    padding: 0 var(--space-4);
    border: 0.5px solid var(--border-strong);
    border-radius: var(--radius-pill);
    background: var(--surface-2);
    color: var(--text-primary);
    font: inherit;
    font-size: 15px;
    cursor: pointer;
    transition: box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .auth-signin[hidden] {
    display: none;
  }
  .auth-signin:hover {
    border-color: var(--text-secondary);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
  }
  .auth-user {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }
  .auth-user[hidden] {
    display: none;
  }
  .auth-avatar {
    width: 28px;
    height: 28px;
    border-radius: var(--radius-pill);
    object-fit: cover;
    background: var(--surface-3, var(--surface-2));
    border: 0.5px solid var(--border);
  }
  .auth-avatar:not([src]) {
    display: none;
  }
  .auth-signout {
    display: inline-flex;
    align-items: center;
    height: 32px;
    padding: 0 var(--space-3);
    border: 0.5px solid var(--border-strong);
    border-radius: var(--radius-pill);
    background: var(--surface-2);
    color: var(--text-secondary);
    font: inherit;
    font-size: 14px;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .auth-signout:hover {
    border-color: var(--text-secondary);
    color: var(--text-primary);
  }
  /* Rounded bordered control, Airbnb-like. */
  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    border: 0.5px solid var(--border-strong);
    border-radius: var(--radius-pill);
    background: var(--surface-2);
    color: var(--text-primary);
    cursor: pointer;
    line-height: 0;
    transition: box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .icon-btn:hover {
    border-color: var(--text-secondary);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
  }

  /* Show moon in light mode (offer switch to dark), sun in dark mode. */
  .icon-moon {
    display: inline-flex;
  }
  .icon-sun {
    display: none;
  }
  :global(:root[data-theme='dark']) .icon-moon {
    display: none;
  }
  :global(:root[data-theme='dark']) .icon-sun {
    display: inline-flex;
  }
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .icon-moon {
      display: none;
    }
    :global(:root:not([data-theme='light'])) .icon-sun {
      display: inline-flex;
    }
  }

  @media (max-width: 560px) {
    .inner {
      padding: var(--space-3) var(--space-4);
      gap: var(--space-3);
    }
    .nav {
      gap: var(--space-4);
    }
    .brand-name {
      display: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var root = document.documentElement;
      var current = root.dataset.theme;
      if (!current) {
        // No explicit theme yet: derive from what's actually shown.
        var isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        current = isDark ? 'dark' : 'light';
      }
      var next = current === 'dark' ? 'light' : 'dark';
      root.dataset.theme = next;
      try {
        localStorage.setItem('theme', next);
      } catch (e) {}
    });
  })();
</script>

<script>
  import {
    onAuthChange,
    signInWithGoogle,
    signOutUser,
    isAuthConfigured,
  } from '../lib/auth.ts';

  const root = document.querySelector<HTMLElement>('[data-auth]');
  if (root && isAuthConfigured()) {
    const signinBtn = root.querySelector<HTMLButtonElement>('[data-auth-signin]');
    const userWrap = root.querySelector<HTMLElement>('[data-auth-user]');
    const avatar = root.querySelector<HTMLImageElement>('[data-auth-avatar]');
    const signoutBtn = root.querySelector<HTMLButtonElement>('[data-auth-signout]');

    // Reveal the control now that the feature is available.
    root.hidden = false;

    onAuthChange((user) => {
      const signedIn = !!user;
      if (signinBtn) signinBtn.hidden = signedIn;
      if (userWrap) userWrap.hidden = !signedIn;
      if (avatar) {
        if (user?.photoURL) {
          avatar.src = user.photoURL;
          avatar.alt = user.displayName ?? '';
        } else {
          avatar.removeAttribute('src');
        }
      }
    });

    signinBtn?.addEventListener('click', () => void signInWithGoogle());
    signoutBtn?.addEventListener('click', () => void signOutUser());
  }
</script>
