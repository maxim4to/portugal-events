---
import Icon from './Icon.astro';

const href = (p: string) => import.meta.env.BASE_URL.replace(/\/$/, '') + p;

const links = [
  { path: '/places/', label: 'Места' },
  { path: '/events/', label: 'Афиша' },
];

// Astro.url.pathname includes the base (e.g. /portugal-events/places/).
// Normalise both sides (strip trailing slash, treat empty as '/') and match by suffix.
const current = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (p: string) => {
  const target = href(p).replace(/\/$/, '') || '/';
  return current === target;
};
---
<header class="site-header">
  <div class="inner">
    <a href={href('/')} class="brand" aria-label="Португалия — на главную">
      <span class="brand-mark" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C7.6 2 4 5.6 4 10c0 5.4 7 11.6 7.3 11.9a1 1 0 0 0 1.4 0C13 21.6 20 15.4 20 10c0-4.4-3.6-8-8-8Zm0 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z"/>
        </svg>
      </span>
      <span class="brand-name">Португалия</span>
    </a>

    <nav class="nav" aria-label="Разделы">
      {links.map((l) => (
        <a
          href={href(l.path)}
          class:list={['nav-link', { active: isActive(l.path) }]}
          data-label={l.label}
          aria-current={isActive(l.path) ? 'page' : undefined}
        >
          <span class="nav-link-text">{l.label}</span>
        </a>
      ))}
    </nav>

    <div class="actions">
      <div class="auth" data-auth hidden>
        <button type="button" class="auth-signin" data-auth-signin hidden>
          <svg class="auth-signin-icon" width="16" height="16" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="1.6" stroke-linecap="round"
               stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="8" r="4" />
            <path d="M4 21c0-4 3.6-7 8-7s8 3 8 7" />
          </svg>
          <span>Войти</span>
        </button>

        <div class="auth-user" data-auth-user hidden>
          <button type="button" class="auth-avatar-btn" data-auth-menu-toggle
                  aria-haspopup="menu" aria-expanded="false" aria-label="Аккаунт">
            <img class="auth-avatar" data-auth-avatar alt="" width="32" height="32"
                 referrerpolicy="no-referrer" />
          </button>
          <div class="auth-menu" data-auth-menu role="menu" hidden>
            <div class="auth-menu-head">
              <span class="auth-menu-name" data-auth-name></span>
              <span class="auth-menu-email muted" data-auth-email></span>
            </div>
            <button type="button" class="auth-menu-item" data-auth-signout role="menuitem">Выйти</button>
          </div>
        </div>
      </div>
      <button class="icon-btn theme-toggle" id="theme-toggle" aria-label="Переключить тему">
        <span class="icon-sun"><Icon name="sun" size={18} /></span>
        <span class="icon-moon"><Icon name="moon" size={18} /></span>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: var(--surface-2);
    border-bottom: 0.5px solid var(--border);
  }
  .inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-5);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    justify-self: start;
    color: var(--accent);
    font-weight: 500;
    font-size: 17px;
  }
  .brand:hover {
    text-decoration: none;
  }
  .brand-mark {
    display: inline-flex;
  }
  .brand-name {
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  /* Centered Airbnb-style tabs with an underline on the active one. */
  .nav {
    display: inline-flex;
    align-items: center;
    gap: var(--space-5);
    justify-self: center;
  }
  .nav-link {
    display: inline-grid;
    position: relative;
    padding: var(--space-2) 0;
    font-size: 15px;
    color: var(--text-secondary);
  }
  /* Reserve the bold (active) width so toggling weight never shifts neighbours. */
  .nav-link::after {
    content: attr(data-label);
    grid-area: 1 / 1;
    font-weight: 500;
    height: 0;
    visibility: hidden;
    pointer-events: none;
  }
  .nav-link-text {
    grid-area: 1 / 1;
  }
  .nav-link:hover {
    text-decoration: none;
    color: var(--text-primary);
  }
  .nav-link.active {
    color: var(--text-primary);
    font-weight: 500;
  }
  .nav-link.active::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 2px;
    border-radius: 2px;
    background: var(--text-primary);
  }

  .actions {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    justify-self: end;
  }

  /* Auth control — a pill matching the theme toggle. */
  .auth[hidden] {
    display: none;
  }
  .auth-signin {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    height: 40px;
    padding: 0 var(--space-4);
    border: 0.5px solid var(--border-strong);
    border-radius: var(--radius-pill);
    background: var(--surface-2);
    color: var(--text-primary);
    font: inherit;
    font-size: 15px;
    cursor: pointer;
    transition: box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .auth-signin[hidden] {
    display: none;
  }
  .auth-signin:hover {
    border-color: var(--text-secondary);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
  }
  .auth-signin-icon {
    color: var(--text-secondary);
    flex: none;
  }
  .auth-user {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .auth-user[hidden] {
    display: none;
  }
  .auth-avatar-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 3px;
    border: 0.5px solid var(--border-strong);
    border-radius: var(--radius-pill);
    background: var(--surface-2);
    cursor: pointer;
    transition: box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .auth-avatar-btn:hover {
    border-color: var(--text-secondary);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
  }
  .auth-avatar {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-pill);
    object-fit: cover;
    display: block;
  }
  .auth-avatar:not([src]) {
    display: none;
  }
  .auth-menu {
    position: absolute;
    top: calc(100% + var(--space-1));
    right: 0;
    z-index: 1000;
    min-width: 200px;
    padding: var(--space-2);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface-2);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.16);
  }
  .auth-menu[hidden] {
    display: none;
  }
  .auth-menu-head {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-2) var(--space-3);
    border-bottom: 0.5px solid var(--border);
    margin-bottom: var(--space-1);
  }
  .auth-menu-name {
    font-size: 14px;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 220px;
  }
  .auth-menu-email {
    font-size: 12px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 220px;
  }
  .auth-menu-item {
    display: block;
    width: 100%;
    padding: var(--space-2) var(--space-3);
    border: 0;
    background: none;
    border-radius: 6px;
    color: var(--text-primary);
    font: inherit;
    font-size: 14px;
    text-align: left;
    cursor: pointer;
  }
  .auth-menu-item:hover {
    background: var(--surface-1);
  }
  /* Rounded bordered control, Airbnb-like. */
  .icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    border: 0.5px solid var(--border-strong);
    border-radius: var(--radius-pill);
    background: var(--surface-2);
    color: var(--text-primary);
    cursor: pointer;
    line-height: 0;
    transition: box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .icon-btn:hover {
    border-color: var(--text-secondary);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
  }

  /* Show moon in light mode (offer switch to dark), sun in dark mode. */
  .icon-moon {
    display: inline-flex;
  }
  .icon-sun {
    display: none;
  }
  :global(:root[data-theme='dark']) .icon-moon {
    display: none;
  }
  :global(:root[data-theme='dark']) .icon-sun {
    display: inline-flex;
  }
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .icon-moon {
      display: none;
    }
    :global(:root:not([data-theme='light'])) .icon-sun {
      display: inline-flex;
    }
  }

  @media (max-width: 560px) {
    .inner {
      padding: var(--space-3) var(--space-4);
      gap: var(--space-3);
    }
    .nav {
      gap: var(--space-4);
    }
    .brand-name {
      display: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var root = document.documentElement;
      var current = root.dataset.theme;
      if (!current) {
        // No explicit theme yet: derive from what's actually shown.
        var isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        current = isDark ? 'dark' : 'light';
      }
      var next = current === 'dark' ? 'light' : 'dark';
      root.dataset.theme = next;
      try {
        localStorage.setItem('theme', next);
      } catch (e) {}
    });
  })();
</script>

<script>
  import {
    onAuthChange,
    signInWithGoogle,
    signOutUser,
    isAuthConfigured,
  } from '../lib/auth.ts';

  const root = document.querySelector<HTMLElement>('[data-auth]');
  if (root && isAuthConfigured()) {
    const signinBtn = root.querySelector<HTMLButtonElement>('[data-auth-signin]');
    const userWrap = root.querySelector<HTMLElement>('[data-auth-user]');
    const avatar = root.querySelector<HTMLImageElement>('[data-auth-avatar]');
    const signoutBtn = root.querySelector<HTMLButtonElement>('[data-auth-signout]');
    const avatarBtn = root.querySelector<HTMLButtonElement>('[data-auth-menu-toggle]');
    const menu = root.querySelector<HTMLElement>('[data-auth-menu]');
    const nameEl = root.querySelector<HTMLElement>('[data-auth-name]');
    const emailEl = root.querySelector<HTMLElement>('[data-auth-email]');

    // Reveal the control now that the feature is available.
    root.hidden = false;

    function setMenu(open: boolean) {
      if (!menu || !avatarBtn) return;
      menu.hidden = !open;
      avatarBtn.setAttribute('aria-expanded', String(open));
    }
    avatarBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      setMenu(menu?.hidden === true);
    });
    document.addEventListener('click', (e) => {
      if (!(e.target as HTMLElement).closest('[data-auth-user]')) setMenu(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { setMenu(false); avatarBtn?.focus(); }
    });

    onAuthChange((user) => {
      const signedIn = !!user;
      if (signinBtn) signinBtn.hidden = signedIn;
      if (userWrap) userWrap.hidden = !signedIn;
      if (avatar) {
        if (user?.photoURL) {
          avatar.src = user.photoURL;
          avatar.alt = user.displayName ?? '';
        } else {
          avatar.removeAttribute('src');
        }
      }
      if (nameEl) nameEl.textContent = user?.displayName ?? '';
      if (emailEl) emailEl.textContent = user?.email ?? '';
      if (!signedIn) setMenu(false);
    });

    signinBtn?.addEventListener('click', () => void signInWithGoogle());
    signoutBtn?.addEventListener('click', () => void signOutUser());
  }
</script>
