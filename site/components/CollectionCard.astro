---
import type { Collection, Place } from '../../schema/index.ts';

interface Props {
  collection: Collection;
  places: Place[];
  href: string;
}
const { collection, places, href } = Astro.props;
const covers = places.slice(0, 3);
---
<a href={href} class="card collection-card">
  <div class="covers">
    {covers.map((place) => (
      <div
        class="cover-tile"
        style={place.photo ? undefined : `background: var(--type-${place.type});`}
      >
        {place.photo && (
          <img src={place.photo.url} alt={place.name} loading="lazy" />
        )}
      </div>
    ))}
  </div>
  <div class="body">
    <h3>{collection.title}</h3>
    <p class="muted count">{places.length} мест</p>
    <p class="desc">{collection.description}</p>
  </div>
</a>

<style>
  .collection-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease;
  }
  .collection-card:hover {
    border-color: var(--border-strong);
    text-decoration: none;
  }
  .covers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    height: 110px;
  }
  .cover-tile {
    position: relative;
    overflow: hidden;
    background: var(--surface-1);
  }
  .cover-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .body {
    padding: var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .body h3 {
    margin: 0;
  }
  .count {
    margin: 0;
    font-size: 14px;
  }
  .desc {
    margin: 0;
    font-size: 14px;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
