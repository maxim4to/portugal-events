---
// Render Instagram reels/posts as embeds so visitors can watch them right on
// the place page. We turn each shared URL into its /embed/ iframe form; the
// caption embed keeps the description visible under the video.
interface Props {
  reels: string[];
  name: string;
}
const { reels, name } = Astro.props;

// Accept /reel/, /p/ and /tv/ links (with or without query strings) and build
// the canonical embed URL. Drop anything we can't parse rather than render a
// broken frame.
const toEmbed = (url: string): string | null => {
  const m = url.match(/instagram\.com\/(reel|p|tv)\/([A-Za-z0-9_-]+)/);
  if (!m) return null;
  return `https://www.instagram.com/${m[1]}/${m[2]}/embed/captioned/`;
};
const embeds = reels.map(toEmbed).filter((u): u is string => u !== null);
---
{embeds.length > 0 && (
  <section class="reels" aria-label={`Reels про ${name}`}>
    <h2 class="reels-title">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
           stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="2" width="20" height="20" rx="5" />
        <path d="m10 8 5 4-5 4V8Z" fill="currentColor" stroke="none" />
      </svg>
      Reels
    </h2>
    <div class="reels-grid">
      {embeds.map((src, i) => (
        <div class="reel-frame">
          <iframe
            src={src}
            title={`Instagram reel ${i + 1} — ${name}`}
            loading="lazy"
            scrolling="no"
            allowtransparency="true"
            allow="encrypted-media; clipboard-write"
          ></iframe>
        </div>
      ))}
    </div>
  </section>
)}

<style>
  .reels {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .reels-title {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0;
    font-family: var(--font-display);
    font-size: 20px;
    color: var(--text-primary);
  }
  .reels-title svg {
    color: var(--editorial);
  }
  .reels-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-4);
  }
  /* Instagram's captioned embed is a tall card; give each a fixed frame that
     scrolls internally if the caption runs long. */
  .reel-frame {
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface-2);
  }
  .reel-frame iframe {
    display: block;
    width: 100%;
    height: 560px;
    border: 0;
  }
  @media (max-width: 480px) {
    .reels-grid {
      grid-template-columns: 1fr;
    }
    .reel-frame iframe {
      height: 620px;
    }
  }
</style>
