---
import type { Place } from '../../schema/index.ts';
import FilterBar from './FilterBar.astro';
import PlaceCard from './PlaceCard.astro';
import VisitedButton from './VisitedButton.astro';
import VisitedController from './VisitedController.astro';
import FavoriteButton from './FavoriteButton.astro';
import FavoriteController from './FavoriteController.astro';
import MapShell from './MapShell.astro';

interface Props {
  places: Place[];
  regions: string[];
  tags: string[];
  hrefBase: string;
}
const { places, regions, tags, hrefBase } = Astro.props;

const points = places.map((p) => ({
  id: p.id,
  name: p.name,
  type: p.type,
  lat: p.coords.lat,
  lon: p.coords.lon,
}));
---
<MapShell kind="places" detailPrefix="/places/" hrefBase={hrefBase} mapId="places-map" points={points}>
  <FilterBar slot="filters" regions={regions} tags={tags} />

  <label class="sort" slot="toolbar" aria-label="Сортировка">
    <span class="sort-label">Сортировка</span>
    <select class="sort-select" data-sort>
      <option value="default">по умолчанию</option>
      <option value="drive-asc">ближе к Лиссабону</option>
      <option value="drive-desc">дальше от Лиссабона</option>
      <option value="name">по названию</option>
    </select>
  </label>

  <div class="grid-cards" slot="list">
    {places.map((p) => (
      <div
        class="card-wrap"
        data-item-card
        data-place-card
        data-id={p.id}
        data-type={p.type}
        data-region={p.region}
        data-drive={p.driveMinutesFromLisbon}
        data-tags={p.tags.join('|')}
        data-name={p.name}
        data-residency={p.freeWithResidency ? 'true' : 'false'}
      >
        <div class="card-actions">
          <FavoriteButton placeId={p.id} variant="card" />
          <VisitedButton placeId={p.id} variant="card" />
        </div>
        <PlaceCard place={p} href={`${hrefBase}/places/${p.id}/`} />
      </div>
    ))}
  </div>
</MapShell>

<VisitedController />
<FavoriteController />

<style>
  .card-wrap {
    position: relative;
  }
  .card-actions {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-1);
  }
  .sort {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    white-space: nowrap;
  }
  .sort-label {
    font-size: 13px;
    color: var(--text-muted);
  }
  .sort-select {
    height: 32px;
    padding: 0 var(--space-2);
    border: 0.5px solid var(--border-strong);
    border-radius: var(--radius);
    background: var(--surface-2);
    color: var(--text-primary);
    font: inherit;
    font-size: 13px;
    cursor: pointer;
  }
  .sort-select:focus-visible {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-bg);
  }
  @media (max-width: 760px) {
    .sort-label {
      display: none;
    }
  }
</style>

<script>
  import { initMapExplorer } from '../lib/mapExplorer.ts';
  import { initFilterGroups, setGroupCount } from '../lib/filterGroups.ts';
  import {
    matchesFilter,
    type ExplorerFilterState,
    type PlaceCardData,
    type VisitedFilter,
  } from '../lib/placeMatch.ts';

  const root = document.querySelector<HTMLElement>('[data-explorer]');
  if (root) {
    const typeChips = Array.from(root.querySelectorAll<HTMLButtonElement>('.chip[data-type]'));
    const regionChips = Array.from(root.querySelectorAll<HTMLButtonElement>('.chip[data-region]'));
    const tagChips = Array.from(root.querySelectorAll<HTMLButtonElement>('.chip[data-tag]'));
    const driveChips = Array.from(root.querySelectorAll<HTMLButtonElement>('.chip[data-drive]'));
    const residencyChip = root.querySelector<HTMLButtonElement>('.chip[data-residency]');
    const visitedChips = Array.from(
      root.querySelectorAll<HTMLButtonElement>('.chip[data-visited-opt]'),
    );
    const searchInput = root.querySelector<HTMLInputElement>('[data-filter="query"]');
    const favToggle = root.querySelector<HTMLButtonElement>('[data-favorites]');
    const sortSelect = root.querySelector<HTMLSelectElement>('[data-sort]');
    const resetButtons = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-reset]'));
    const grid = root.querySelector<HTMLElement>('.grid-cards');

    const isOn = (el: Element | null) => el?.getAttribute('aria-pressed') === 'true';
    const press = (el: Element, on: boolean) =>
      el.setAttribute('aria-pressed', on ? 'true' : 'false');

    function readState(): ExplorerFilterState {
      return {
        types: typeChips.filter(isOn).map((c) => c.dataset.type!),
        region: regionChips.find(isOn)?.dataset.region ?? '',
        tags: tagChips.filter(isOn).map((c) => c.dataset.tag!),
        maxDrive: Number(driveChips.find(isOn)?.dataset.drive ?? 240),
        query: searchInput?.value ?? '',
        visited: (visitedChips.find(isOn)?.dataset.visitedOpt as VisitedFilter) || 'all',
        onlyFavorites: isOn(favToggle),
        freeWithResidency: isOn(residencyChip),
      };
    }

    function cardData(el: HTMLElement): PlaceCardData {
      return {
        type: el.dataset.type!,
        region: el.dataset.region!,
        drive: Number(el.dataset.drive),
        tags: (el.dataset.tags || '').split('|').filter(Boolean),
        name: el.dataset.name!,
        visited: el.dataset.visited === 'true',
        favorite: el.dataset.favorite === 'true',
        freeWithResidency: el.dataset.residency === 'true',
      };
    }

    const matches = (el: HTMLElement) => matchesFilter(cardData(el), readState());
    const explorer = initMapExplorer(root, { matches });

    // ---- Sorting: reorder the list DOM (markers/visibility are order-agnostic). --
    const cardWraps = grid
      ? Array.from(grid.querySelectorAll<HTMLElement>('[data-item-card]'))
      : [];
    const originalOrder = cardWraps.slice();
    const collator = new Intl.Collator('ru');

    function applySort() {
      if (!grid) return;
      const mode = sortSelect?.value ?? 'default';
      let ordered = originalOrder;
      if (mode === 'drive-asc') {
        ordered = originalOrder
          .slice()
          .sort((a, b) => Number(a.dataset.drive) - Number(b.dataset.drive));
      } else if (mode === 'drive-desc') {
        ordered = originalOrder
          .slice()
          .sort((a, b) => Number(b.dataset.drive) - Number(a.dataset.drive));
      } else if (mode === 'name') {
        ordered = originalOrder
          .slice()
          .sort((a, b) => collator.compare(a.dataset.name || '', b.dataset.name || ''));
      }
      for (const el of ordered) grid.appendChild(el);
    }

    // ---- URL <-> filter state sync ------------------------------------------
    function anyActive(s: ExplorerFilterState): boolean {
      return Boolean(
        s.types.length ||
          s.region ||
          s.tags.length ||
          s.maxDrive !== 240 ||
          s.query.trim() ||
          s.visited !== 'all' ||
          s.onlyFavorites ||
          s.freeWithResidency,
      );
    }

    function writeUrl(s: ExplorerFilterState) {
      const params = new URLSearchParams();
      if (s.query.trim()) params.set('q', s.query.trim());
      if (s.types.length) params.set('type', s.types.join(','));
      if (s.region) params.set('region', s.region);
      if (s.tags.length) params.set('tag', s.tags.join(','));
      if (s.maxDrive !== 240) params.set('drive', String(s.maxDrive));
      if (s.visited !== 'all') params.set('visited', s.visited);
      if (s.onlyFavorites) params.set('fav', '1');
      if (s.freeWithResidency) params.set('residency', '1');
      const sort = sortSelect?.value ?? 'default';
      if (sort !== 'default') params.set('sort', sort);
      const qs = params.toString();
      history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
    }

    function onFilterChange() {
      const s = readState();
      setGroupCount(root, 'type', s.types.length);
      setGroupCount(root, 'region', s.region ? 1 : 0);
      setGroupCount(root, 'tags', s.tags.length);
      setGroupCount(root, 'drive', s.maxDrive !== 240 ? 1 : 0);
      setGroupCount(root, 'more', (s.freeWithResidency ? 1 : 0) + (s.visited !== 'all' ? 1 : 0));
      resetButtons.forEach((b) => (b.hidden = !anyActive(s)));
      writeUrl(s);
      explorer.rerender();
    }

    // The summary pill toggles its group open (one at a time; tap outside closes).
    initFilterGroups(root);

    // Multi-select toggles: types and tags.
    [...typeChips, ...tagChips].forEach((c) =>
      c.addEventListener('click', () => {
        press(c, !isOn(c));
        onFilterChange();
      }),
    );

    // Boolean toggle: residency.
    residencyChip?.addEventListener('click', () => {
      press(residencyChip, !isOn(residencyChip));
      onFilterChange();
    });

    // Single-select with deselect: region and visited.
    const singleSelect = (chips: HTMLButtonElement[], clicked: HTMLButtonElement) => {
      const was = isOn(clicked);
      chips.forEach((c) => press(c, false));
      press(clicked, !was);
      onFilterChange();
    };
    regionChips.forEach((c) =>
      c.addEventListener('click', () => singleSelect(regionChips, c)),
    );
    visitedChips.forEach((c) =>
      c.addEventListener('click', () => singleSelect(visitedChips, c)),
    );

    // Radio: drive presets — one is always active.
    driveChips.forEach((c) =>
      c.addEventListener('click', () => {
        driveChips.forEach((o) => press(o, false));
        press(c, true);
        onFilterChange();
      }),
    );

    // Favorites toggle.
    favToggle?.addEventListener('click', () => {
      press(favToggle, !isOn(favToggle));
      onFilterChange();
    });

    // Re-filter only when the favorites filter is active (e.g. un-hearting a
    // place while viewing favorites). Otherwise a toggle changes nothing shown,
    // so we avoid a needless map refit.
    document.addEventListener('favorites:changed', () => {
      if (isOn(favToggle)) explorer.rerender();
    });

    // Search: filter as you type.
    searchInput?.addEventListener('input', onFilterChange);

    // Sort: pure reorder, no re-filter needed.
    sortSelect?.addEventListener('change', () => {
      applySort();
      writeUrl(readState());
    });

    // Reset: clear every filter and the search box.
    resetButtons.forEach((b) =>
      b.addEventListener('click', () => {
        [...typeChips, ...tagChips, ...visitedChips].forEach((c) => press(c, false));
        regionChips.forEach((c) => press(c, false));
        if (residencyChip) press(residencyChip, false);
        if (favToggle) press(favToggle, false);
        driveChips.forEach((c) => press(c, c.dataset.drive === '240'));
        if (searchInput) searchInput.value = '';
        onFilterChange();
      }),
    );

    // ---- Restore state from the URL on load. --------------------------------
    const params = new URLSearchParams(location.search);
    const setMulti = (chips: HTMLButtonElement[], key: string, raw: string | null) => {
      if (!raw) return;
      const wanted = new Set(raw.split(',').map((s) => s.trim()).filter(Boolean));
      chips.forEach((c) => {
        if (wanted.has(c.dataset[key]!)) press(c, true);
      });
    };
    if (searchInput && params.get('q')) searchInput.value = params.get('q')!;
    setMulti(typeChips, 'type', params.get('type'));
    setMulti(tagChips, 'tag', params.get('tag'));
    const preRegion = params.get('region');
    if (preRegion) {
      const chip = regionChips.find((c) => c.dataset.region === preRegion);
      if (chip) press(chip, true);
    }
    const preDrive = params.get('drive');
    if (preDrive && driveChips.some((c) => c.dataset.drive === preDrive)) {
      driveChips.forEach((c) => press(c, c.dataset.drive === preDrive));
    }
    const preVisited = params.get('visited');
    if (preVisited === 'visited' || preVisited === 'unvisited') {
      const chip = visitedChips.find((c) => c.dataset.visitedOpt === preVisited);
      if (chip) press(chip, true);
    }
    if (params.get('residency') === '1' && residencyChip) press(residencyChip, true);
    if (params.get('fav') === '1' && favToggle) press(favToggle, true);
    const preSort = params.get('sort');
    if (sortSelect && preSort) sortSelect.value = preSort;

    applySort();
    onFilterChange();
  }
</script>
