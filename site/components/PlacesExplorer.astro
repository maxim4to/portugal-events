---
import type { Place } from '../../schema/index.ts';
import FilterBar from './FilterBar.astro';
import PlaceCard from './PlaceCard.astro';
import VisitedButton from './VisitedButton.astro';
import VisitedController from './VisitedController.astro';
import MapShell from './MapShell.astro';

interface Props {
  places: Place[];
  regions: string[];
  tags: string[];
  hrefBase: string;
}
const { places, regions, tags, hrefBase } = Astro.props;

const points = places.map((p) => ({
  id: p.id,
  name: p.name,
  type: p.type,
  lat: p.coords.lat,
  lon: p.coords.lon,
}));
---
<MapShell kind="places" detailPrefix="/places/" hrefBase={hrefBase} mapId="places-map" points={points}>
  <FilterBar slot="filters" regions={regions} tags={tags} />

  <div class="grid-cards" slot="list">
    {places.map((p) => (
      <div
        class="card-wrap"
        data-item-card
        data-id={p.id}
        data-type={p.type}
        data-region={p.region}
        data-drive={p.driveMinutesFromLisbon}
        data-tags={p.tags.join('|')}
        data-name={p.name}
        data-residency={p.freeWithResidency ? 'true' : 'false'}
      >
        <VisitedButton placeId={p.id} variant="card" />
        <PlaceCard place={p} href={`${hrefBase}/places/${p.id}/`} />
      </div>
    ))}
  </div>
</MapShell>

<VisitedController />

<style>
  .card-wrap {
    position: relative;
  }
</style>

<script>
  import { initMapExplorer } from '../lib/mapExplorer.ts';
  import {
    matchesFilter,
    type ExplorerFilterState,
    type PlaceCardData,
    type VisitedFilter,
  } from '../lib/placeMatch.ts';

  const root = document.querySelector<HTMLElement>('[data-explorer]');
  if (root) {
    const typeChips = Array.from(root.querySelectorAll<HTMLButtonElement>('.chip[data-type]'));
    const regionChips = Array.from(root.querySelectorAll<HTMLButtonElement>('.chip[data-region]'));
    const tagChips = Array.from(root.querySelectorAll<HTMLButtonElement>('.chip[data-tag]'));
    const driveChips = Array.from(root.querySelectorAll<HTMLButtonElement>('.chip[data-drive]'));
    const residencyChip = root.querySelector<HTMLButtonElement>('.chip[data-residency]');
    const visitedChips = Array.from(
      root.querySelectorAll<HTMLButtonElement>('.chip[data-visited-opt]'),
    );

    const isOn = (el: Element | null) => el?.getAttribute('aria-pressed') === 'true';
    const press = (el: Element, on: boolean) =>
      el.setAttribute('aria-pressed', on ? 'true' : 'false');

    function readState(): ExplorerFilterState {
      return {
        types: typeChips.filter(isOn).map((c) => c.dataset.type!),
        region: regionChips.find(isOn)?.dataset.region ?? '',
        tags: tagChips.filter(isOn).map((c) => c.dataset.tag!),
        maxDrive: Number(driveChips.find(isOn)?.dataset.drive ?? 240),
        query: '',
        visited: (visitedChips.find(isOn)?.dataset.visitedOpt as VisitedFilter) || 'all',
        freeWithResidency: isOn(residencyChip),
      };
    }

    function cardData(el: HTMLElement): PlaceCardData {
      return {
        type: el.dataset.type!,
        region: el.dataset.region!,
        drive: Number(el.dataset.drive),
        tags: (el.dataset.tags || '').split('|').filter(Boolean),
        name: el.dataset.name!,
        visited: el.dataset.visited === 'true',
        freeWithResidency: el.dataset.residency === 'true',
      };
    }

    const matches = (el: HTMLElement) => matchesFilter(cardData(el), readState());
    const explorer = initMapExplorer(root, { matches });

    function setGroupCount(key: string, n: number) {
      const group = root!.querySelector<HTMLElement>(`[data-fgroup="${key}"]`);
      if (!group) return;
      group.classList.toggle('active', n > 0);
      const badge = group.querySelector<HTMLElement>('[data-fcount]');
      if (badge) badge.textContent = n > 0 ? String(n) : '';
    }

    function onFilterChange() {
      const s = readState();
      setGroupCount('type', s.types.length);
      setGroupCount('region', s.region ? 1 : 0);
      setGroupCount('tags', s.tags.length);
      setGroupCount('drive', s.maxDrive !== 240 ? 1 : 0);
      setGroupCount('more', (s.freeWithResidency ? 1 : 0) + (s.visited !== 'all' ? 1 : 0));
      explorer.rerender();
    }

    // Mobile dropdowns: the summary pill toggles its group open; one at a time;
    // tap outside closes. On desktop the summary is inert (pointer-events:none)
    // and every group's chips are shown inline, so none of this runs.
    const groups = Array.from(root.querySelectorAll<HTMLElement>('.fgroup'));
    groups.forEach((g) => {
      const btn = g.querySelector<HTMLButtonElement>('[data-fgroup-toggle]');
      btn?.addEventListener('click', () => {
        const willOpen = !g.classList.contains('open');
        groups.forEach((o) => {
          o.classList.toggle('open', o === g && willOpen);
          o.querySelector('[data-fgroup-toggle]')?.setAttribute(
            'aria-expanded',
            String(o === g && willOpen),
          );
        });
      });
    });
    document.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('.fgroup')) return;
      groups.forEach((g) => {
        g.classList.remove('open');
        g.querySelector('[data-fgroup-toggle]')?.setAttribute('aria-expanded', 'false');
      });
    });

    // Multi-select toggles: types and tags.
    [...typeChips, ...tagChips].forEach((c) =>
      c.addEventListener('click', () => {
        press(c, !isOn(c));
        onFilterChange();
      }),
    );

    // Boolean toggle: residency.
    residencyChip?.addEventListener('click', () => {
      press(residencyChip, !isOn(residencyChip));
      onFilterChange();
    });

    // Single-select with deselect: region and visited.
    const singleSelect = (chips: HTMLButtonElement[], clicked: HTMLButtonElement) => {
      const was = isOn(clicked);
      chips.forEach((c) => press(c, false));
      press(clicked, !was);
      onFilterChange();
    };
    regionChips.forEach((c) =>
      c.addEventListener('click', () => singleSelect(regionChips, c)),
    );
    visitedChips.forEach((c) =>
      c.addEventListener('click', () => singleSelect(visitedChips, c)),
    );

    // Radio: drive presets — one is always active.
    driveChips.forEach((c) =>
      c.addEventListener('click', () => {
        driveChips.forEach((o) => press(o, false));
        press(c, true);
        onFilterChange();
      }),
    );

    // Preload filters from URL query params (links from detail pages).
    const params = new URLSearchParams(location.search);
    const preType = params.get('type');
    if (preType) {
      const chip = typeChips.find((c) => c.dataset.type === preType);
      if (chip) press(chip, true);
    }
    const preTag = params.get('tag');
    if (preTag) {
      const chip = tagChips.find((c) => c.dataset.tag === preTag);
      if (chip) press(chip, true);
    }

    onFilterChange();
  }
</script>
